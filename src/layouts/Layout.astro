---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  jsonld?: Record<string, any>;
}
const { title, description = 'Johnny Watts Agency — Your trusted insurance specialists in Taylorsville, NC. Medicare, Health Insurance Marketplace, and Life Insurance.', jsonld } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Varela+Round&family=Montserrat:wght@300;400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Varela+Round&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Varela+Round&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" /></noscript>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "InsuranceAgency",
      "name": "Johnny Watts Agency",
      "url": "https://johnnywattsagency.com",
      "telephone": "+1-828-635-4200",
      "email": "johnny@johnnywattsagency.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "351 NC Hwy 16 S",
        "addressLocality": "Taylorsville",
        "addressRegion": "NC",
        "postalCode": "28681",
        "addressCountry": "US"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:30",
        "closes": "17:00"
      },
      "sameAs": [
        "https://www.facebook.com/johnnywatts/",
        "https://www.linkedin.com/in/johnny-watts-687b1719"
      ],
      "description": "Your trusted Medicare, Health Insurance Marketplace, and Life Insurance specialists serving North Carolina for over 40 years.",
      "areaServed": {
        "@type": "State",
        "name": "North Carolina"
      },
      "foundingDate": "1984",
      "founder": {
        "@type": "Person",
        "name": "Johnny Watts"
      }
    })} />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YRRF97BTZL"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YRRF97BTZL');
      gtag('config', 'AW-11481493068');
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-white text-dark">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      import AOS from 'aos';
      import 'aos/dist/aos.css';
      AOS.init({
        duration: 800,
        easing: 'ease-out-cubic',
        once: true,
        offset: 80,
      });
    </script>
  </body>
</html>
