---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  jsonld?: Record<string, any>;
  preloadImage?: string;
}
const { title, description = 'Johnny Watts Agency — Your trusted insurance specialists in Taylorsville, NC. Medicare, Health Insurance Marketplace, and Life Insurance.', jsonld, preloadImage } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} type="image/webp" />}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/w8gdH283Tvk__Lua32TysjIfp8uP.woff2" crossorigin />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "InsuranceAgency",
      "name": "Johnny Watts Agency",
      "url": "https://johnnywattsagency.com",
      "telephone": "+1-828-635-4200",
      "email": "johnny@johnnywattsagency.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "351 NC Hwy 16 S",
        "addressLocality": "Taylorsville",
        "addressRegion": "NC",
        "postalCode": "28681",
        "addressCountry": "US"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "17:00"
      },
      "sameAs": [
        "https://www.facebook.com/johnnywatts/",
        "https://www.linkedin.com/in/johnny-watts-687b1719"
      ],
      "description": "Your trusted Medicare, Health Insurance Marketplace, and Life Insurance specialists serving North Carolina for over 40 years.",
      "areaServed": {
        "@type": "State",
        "name": "North Carolina"
      },
      "foundingDate": "1984",
      "founder": {
        "@type": "Person",
        "name": "Johnny Watts"
      }
    })} />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}

    <!-- Google Analytics (GA4) — deferred for performance -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YRRF97BTZL');
      gtag('config', 'AW-11481493068');
      setTimeout(function(){
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-YRRF97BTZL';
        document.head.appendChild(s);
      }, 2000);
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-white text-dark">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:text-sm focus:font-semibold">Skip to main content</a>
    <Nav />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <style>
      [data-aos] { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
      [data-aos].aos-done { opacity: 1; transform: translateY(0); }
    </style>
    <script>
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const d = e.target.getAttribute('data-aos-delay');
            if (d) { setTimeout(() => e.target.classList.add('aos-done'), parseInt(d)); }
            else { e.target.classList.add('aos-done'); }
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.05 });
      document.querySelectorAll('[data-aos]').forEach(el => obs.observe(el));
    </script>
  </body>
</html>
