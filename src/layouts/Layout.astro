---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  jsonld?: Record<string, any>;
}
const { title, description = 'Johnny Watts Agency — Your trusted insurance specialists in Taylorsville, NC. Medicare, Health Insurance Marketplace, and Life Insurance.', jsonld } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- TLS warmup for LCP-critical origins -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Preload critical fonts — Varela Round 400 (H1) + Montserrat 300 (body).
         Other weights arrive with the async Tailwind bundle. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/w8gdH283Tvk__Lua32TysjIfp8uP.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2" crossorigin />

    <!-- Per-page head slot — hoisted so page-specific LCP preloads (e.g. hero image) come early -->
    <slot name="head-early" />

    <!-- ========================================================================
         CRITICAL CSS — hand-rolled coverage of above-fold utilities.
         @font-face + @keyframes stay unlayered (CSS spec forbids them in @layer).
         Everything else lives in @layer base so Tailwind v4's async @layer
         utilities wins the cascade when the full bundle arrives.
         ======================================================================== -->
    <style is:inline>
      /* --- critical @font-face (unlayered per CSS spec) --- */
      @font-face{font-family:'Varela Round';font-style:normal;font-weight:400;font-display:optional;src:url('/fonts/w8gdH283Tvk__Lua32TysjIfp8uP.woff2') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
      @font-face{font-family:'Montserrat';font-style:normal;font-weight:300;font-display:optional;src:url('/fonts/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
      @font-face{font-family:'Montserrat';font-style:normal;font-weight:500;font-display:optional;src:url('/fonts/JTUSjIg1_i6t8kCHKm459Wlhyw.woff2') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
      @font-face{font-family:'Varela Round Fallback';src:local('Arial');size-adjust:103%;ascent-override:95%;descent-override:21%;line-gap-override:0%}
      @font-face{font-family:'Montserrat Fallback';src:local('Arial');size-adjust:104%;ascent-override:85%;descent-override:22%;line-gap-override:0%}

      @layer base {
        /* resets */
        *,*::before,*::after{box-sizing:border-box;border:0 solid}
        html{-webkit-text-size-adjust:100%;scroll-behavior:smooth;-webkit-font-smoothing:antialiased;font-family:'Montserrat','Montserrat Fallback',system-ui,-apple-system,sans-serif;color:#353535;background-color:#ffffff}
        body{margin:0;background:#ffffff;color:#353535;line-height:1.4}
        img,picture,svg,video,canvas{display:block;max-width:100%;height:auto}
        h1,h2,h3,h4,h5,h6{margin:0;font-family:'Varela Round','Varela Round Fallback',system-ui,sans-serif;font-weight:300;line-height:1.2;overflow-wrap:break-word}
        p{margin:0;font-size:1rem;font-weight:300;line-height:1.4;overflow-wrap:break-word}
        a{color:inherit;text-decoration:none;transition:color .2s ease}
        button{font:inherit;color:inherit;background:transparent;cursor:pointer;padding:0;border:0}

        /* JWA custom component classes — hex literals only */
        .kicker{font-family:'Montserrat','Montserrat Fallback',system-ui,sans-serif;font-size:.875rem;font-weight:500;letter-spacing:.05em;text-transform:capitalize;color:#4632DA;margin-bottom:.25rem}
        .gradient-badge{background:linear-gradient(130deg,#4632DA,#06D9FA)}
        .font-heading{font-family:'Varela Round','Varela Round Fallback',system-ui,sans-serif}
        .font-light{font-weight:300}
        .text-clamp-hero-sm{font-size:clamp(28px,5vw,45px)}
        .text-clamp-hero{font-size:clamp(28px,5vw,55px)}
        .text-clamp-cta{font-size:clamp(1.75rem,4vw,2.5rem)}
        .hero-btn{transition:background-color .3s ease,color .3s ease,transform .2s ease}
        .hero-btn.bg-accent{background-color:#06D9FA;color:#4632DA}
        .hero-btn.bg-accent:hover{background-color:#4632DA!important;color:#fff!important}
        .hero-btn:hover{background-color:#4632DA!important;transform:translateY(-1px)}
        .btn-shine{position:relative;overflow:hidden}
        .blob-shape-3{border-radius:300px 100px 100px 100px;box-shadow:0 0 30px 0 rgba(0,0,0,.12)}
        .hover-tilt{transition:transform .4s ease}
        .wave-svg{display:block;width:calc(250% + 100.3px);position:relative;left:50%;transform:translateX(-50%) rotate(180deg) scaleX(-1);height:100px}

        /* Nav-specific utilities — match Nav.astro's scoped <style> exactly so
           initial paint uses the final link height and the nav doesn't reflow. */
        .nav-link{display:inline-flex;align-items:center;padding:35px 25px;white-space:nowrap;font-family:'Varela Round','Varela Round Fallback',system-ui,sans-serif;font-size:15px;font-weight:300;color:#FFFEFE;text-decoration:none;text-transform:capitalize;transition:color .2s}
        .nav-header{box-shadow:0 10px 20px 0 rgba(0,0,0,.1)}

        /* Tailwind utility copies used above the fold — union of nav + hero.
           External @layer utilities overrides these once the async bundle loads. */
        .flex{display:flex}.inline-flex{display:inline-flex}.grid{display:grid}.block{display:block}.hidden{display:none}.inline-block{display:inline-block}
        .items-center{align-items:center}.items-start{align-items:flex-start}
        .justify-between{justify-content:space-between}.justify-center{justify-content:center}
        .flex-col{flex-direction:column}.flex-row{flex-direction:row}.flex-wrap{flex-wrap:wrap}.shrink-0{flex-shrink:0}.flex-1{flex:1 1 0%}
        .gap-0{gap:0}.gap-1{gap:.25rem}.gap-2{gap:.5rem}.gap-4{gap:1rem}.gap-6{gap:1.5rem}.gap-8{gap:2rem}
        .relative{position:relative}.absolute{position:absolute}.sticky{position:sticky}.fixed{position:fixed}
        .top-0{top:0}.left-0{left:0}.right-0{right:0}.inset-0{inset:0}.bottom-\[-1px\]{bottom:-1px}
        .z-0{z-index:0}.z-10{z-index:10}.z-50{z-index:50}.z-\[1\]{z-index:1}.z-\[2\]{z-index:2}
        .h-4{height:1rem}.h-6{height:1.5rem}.h-10{height:2.5rem}.h-20{height:5rem}.h-auto{height:auto}.h-full{height:100%}.h-\[90px\]{height:90px}
        .w-4{width:1rem}.w-6{width:1.5rem}.w-\[140px\]{width:140px}.w-full{width:100%}.w-auto{width:auto}
        .min-h-screen{min-height:100vh}.min-h-\[580px\]{min-height:580px}.min-h-\[420px\]{min-height:420px}
        .max-w-\[1250px\]{max-width:1250px}.max-w-2xl{max-width:42rem}
        .mx-auto{margin-inline:auto}
        .mb-4{margin-bottom:1rem}.mb-6{margin-bottom:1.5rem}.-mb-\[15\%\]{margin-bottom:-15%}.-mb-\[60px\]{margin-bottom:-60px}
        .px-\[2\%\]{padding-left:2%;padding-right:2%}.px-6{padding-inline:1.5rem}.px-7{padding-inline:1.75rem}.px-8{padding-inline:2rem}
        .py-3{padding-block:.75rem}.py-3\.5{padding-block:.875rem}.pt-\[80px\]{padding-top:80px}.pb-\[30px\]{padding-bottom:30px}
        .p-2{padding:.5rem}.p-3{padding:.75rem}.p-5{padding:1.25rem}
        .rounded-full{border-radius:9999px}.rounded-md{border-radius:.375rem}
        .bg-white{background-color:#fff}.bg-accent{background-color:#087A8E}.bg-primary{background-color:#4632DA}
        .text-white{color:#fff}.text-white\/90{color:rgba(255,255,255,.9)}.text-accent{color:#087A8E}.text-primary{color:#4632DA}.text-dark{color:#353535}.text-black{color:#000}
        .text-base{font-size:1rem}.text-sm{font-size:.875rem}.text-xs{font-size:.75rem}
        .font-medium{font-weight:500}.font-semibold{font-weight:600}.font-bold{font-weight:700}
        .leading-\[1\.2\]{line-height:1.2}.leading-\[1\.4\]{line-height:1.4}.leading-none{line-height:1}
        .capitalize{text-transform:capitalize}.text-center{text-align:center}.text-left{text-align:left}
        .overflow-hidden{overflow:hidden}
        .object-contain{object-fit:contain}.object-cover{object-fit:cover}
        .pointer-events-none{pointer-events:none}
        .bg-no-repeat{background-repeat:no-repeat}.bg-center{background-position:center}.bg-cover{background-size:cover}
        .opacity-\[0\.15\]{opacity:.15}

        /* Skip link */
        .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

        /* Mobile drawer — must start off-screen BEFORE async CSS loads or
           its content shifts the page. Covers #drawer + #drawer-overlay. */
        .fixed{position:fixed}.h-full{height:100%}
        .w-\[280px\]{width:280px}.z-\[60\]{z-index:60}.z-\[70\]{z-index:70}
        .bg-gradient-drawer{background:linear-gradient(180deg,#4632DA 0%,#2a7de8 50%,#06D9FA 100%)}
        .drawer-hidden{transform:translateX(-100%);transition:transform .3s cubic-bezier(.22,1,.36,1)}
        /* Both #drawer and #drawer-overlay carry .lg:hidden; on mobile the
           drawer is translate(-100%) offscreen and the overlay is .hidden
           (display:none from base utility) */
        .bg-black\/50{background-color:rgba(0,0,0,.5)}
        .opacity-0{opacity:0}

        /* Responsive variants above fold */
        @media(min-width:768px){
          .md\:flex-row{flex-direction:row}
          .md\:w-1\/2{width:50%}
          .md\:w-1\/3{width:33.333333%}
          .md\:w-2\/3{width:66.666667%}
          .md\:w-\[45\%\]{width:45%}
          .md\:w-\[55\%\]{width:55%}
          .md\:py-28{padding-top:7rem;padding-bottom:7rem}
        }
        @media(min-width:1024px){
          .lg\:flex{display:flex}
          .lg\:hidden{display:none}
          .lg\:w-1\/3{width:33.333333%}
          .lg\:w-2\/3{width:66.666667%}
          .lg\:w-\[20\%\]{width:20%}
          .lg\:w-\[30\%\]{width:30%}
          .lg\:w-\[70\%\]{width:70%}
        }
      }

      /* @keyframes must live outside @layer (CSS spec) */
      @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}

      /* UNLAYERED — must match the unlayered rule in src/styles/global.css.
         :not(.absolute) skips waves/bg overlays/blob decorations that live
         as direct section children. Without the guard, the wave SVG gets
         20px left/right padding and pulls away from the viewport edges. */
      @media(max-width:767px){
        section > div:not(.absolute), article > div:not(.absolute) {
          padding-left: max(var(--tw-px,0px), 20px);
          padding-right: max(var(--tw-px,0px), 20px);
        }
      }
    </style>

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.webp', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "InsuranceAgency",
      "name": "Johnny Watts Agency",
      "url": "https://johnnywattsagency.com",
      "telephone": "+1-828-635-4200",
      "email": "johnny@johnnywattsagency.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "351 NC Hwy 16 S",
        "addressLocality": "Taylorsville",
        "addressRegion": "NC",
        "postalCode": "28681",
        "addressCountry": "US"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "17:00"
      },
      "sameAs": [
        "https://www.facebook.com/johnnywatts/",
        "https://www.linkedin.com/in/johnny-watts-687b1719"
      ],
      "description": "Your trusted Medicare, Health Insurance Marketplace, and Life Insurance specialists serving North Carolina for over 40 years.",
      "areaServed": {
        "@type": "State",
        "name": "North Carolina"
      },
      "foundingDate": "1984",
      "founder": {
        "@type": "Person",
        "name": "Johnny Watts"
      }
    })} />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}

    <!-- Per-page head slot (keywords, per-page JSON-LD) -->
    <slot name="head" />

    <!-- Google Analytics (GA4 + Ads) — loaded on first user interaction.
         Pattern: scroll/mousemove/touchstart/keydown/click triggers load
         with an 8s fallback timeout. -->
    <script is:inline>
      (function(){
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        function loadGA(){
          if(window.__gaLoaded) return;
          window.__gaLoaded = true;
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-YRRF97BTZL';
          document.head.appendChild(s);
          gtag('js', new Date());
          gtag('config', 'G-YRRF97BTZL');
          gtag('config', 'AW-11481493068');
        }
        var gaEvents = ['scroll','mousemove','touchstart','keydown','click'];
        function gaTrigger(){ gaEvents.forEach(function(e){ window.removeEventListener(e, gaTrigger); }); loadGA(); }
        gaEvents.forEach(function(e){ window.addEventListener(e, gaTrigger, { passive:true, once:true }); });
        setTimeout(function(){ if(!window.__gaLoaded) loadGA(); }, 8000);
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-white text-dark">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:text-sm focus:font-semibold">Skip to main content</a>
    <Nav />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <style>
      /* data-aos: transform-only (no opacity) to avoid Lighthouse mid-fade contrast failures */
      [data-aos] { opacity: 1; transition: transform 0.6s ease-out; }
    </style>
    <script>
      function initAOS() {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              const d = e.target.getAttribute('data-aos-delay');
              if (d) { setTimeout(() => e.target.classList.add('aos-done'), parseInt(d)); }
              else { e.target.classList.add('aos-done'); }
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.05 });
        document.querySelectorAll('[data-aos]').forEach(el => obs.observe(el));
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAOS);
      } else {
        initAOS();
      }
    </script>
  </body>
</html>
