---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  jsonld?: Record<string, any>;
  preloadImage?: string;
}
const { title, description = 'Johnny Watts Agency — Your trusted insurance specialists in Taylorsville, NC. Medicare, Health Insurance Marketplace, and Life Insurance.', jsonld, preloadImage } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('/og-image.webp', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} type="image/webp" fetchpriority="high" />}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <!-- Preload only the Varela Round woff2 used by the H1 (LCP-critical) -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/w8gdH283Tvk__Lua32TysjIfp8uP.woff2" crossorigin />
    <!-- Below-fold fonts (400/600/700) — shipped as plain stylesheet (non-blocking with font-display:swap) -->
    <link rel="stylesheet" href="/deferred.css" />
    <!-- Critical above-fold responsive rules. Inlined in <head> to guarantee Beasties preserves them. -->
    <style is:inline>
      /* Prevent CLS on flex rows that use `md:w-1/2` before external CSS loads */
      @media (min-width: 48rem) {
        .md\:w-1\/2 { width: 50%; }
        .md\:w-1\/3 { width: 33.333333%; }
        .md\:w-2\/3 { width: 66.666667%; }
      }
      @media (min-width: 64rem) {
        .lg\:w-1\/3 { width: 33.333333%; }
        .lg\:w-2\/3 { width: 66.666667%; }
        .lg\:w-\[30\%\] { width: 30%; }
        .lg\:w-\[70\%\] { width: 70%; }
      }
    </style>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "InsuranceAgency",
      "name": "Johnny Watts Agency",
      "url": "https://johnnywattsagency.com",
      "telephone": "+1-828-635-4200",
      "email": "johnny@johnnywattsagency.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "351 NC Hwy 16 S",
        "addressLocality": "Taylorsville",
        "addressRegion": "NC",
        "postalCode": "28681",
        "addressCountry": "US"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "17:00"
      },
      "sameAs": [
        "https://www.facebook.com/johnnywatts/",
        "https://www.linkedin.com/in/johnny-watts-687b1719"
      ],
      "description": "Your trusted Medicare, Health Insurance Marketplace, and Life Insurance specialists serving North Carolina for over 40 years.",
      "areaServed": {
        "@type": "State",
        "name": "North Carolina"
      },
      "foundingDate": "1984",
      "founder": {
        "@type": "Person",
        "name": "Johnny Watts"
      }
    })} />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}

    <!-- Google Analytics (GA4) — deferred until after user interaction or 5s idle -->
    <script is:inline>
      (function(){
        var loaded = false;
        function loadGA(){
          if(loaded) return;
          loaded = true;
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', 'G-YRRF97BTZL');
          gtag('config', 'AW-11481493068');
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-YRRF97BTZL';
          s.async = true;
          document.head.appendChild(s);
        }
        // Load on first user interaction or after 5s idle
        ['scroll','click','touchstart','keydown'].forEach(function(e){
          document.addEventListener(e, loadGA, {once:true,passive:true});
        });
        setTimeout(loadGA, 5000);
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-white text-dark">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:text-sm focus:font-semibold">Skip to main content</a>
    <Nav />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <style>
      /* Fade only — no translateY, which causes CLS. */
      [data-aos] { opacity: 0; transition: opacity 0.6s ease-out; }
      [data-aos].aos-done { opacity: 1; }
    </style>
    <script>
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const d = e.target.getAttribute('data-aos-delay');
            if (d) { setTimeout(() => e.target.classList.add('aos-done'), parseInt(d)); }
            else { e.target.classList.add('aos-done'); }
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.05 });
      document.querySelectorAll('[data-aos]').forEach(el => obs.observe(el));
    </script>
  </body>
</html>
