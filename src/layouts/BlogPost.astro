---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
}
const { title, description, date } = Astro.props;
---

<Layout title={`${title} — Johnny Watts Agency`} description={description}>
  <article>
    <header class="bg-dark text-white py-16">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-sm text-gray-400 mb-3">{date}</p>
        <h1 class="text-white">{title}</h1>
      </div>
    </header>

    <div class="py-16">
      <div class="max-w-3xl mx-auto px-4 prose-content">
        <slot />
      </div>
    </div>
  </article>

  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Need Insurance Guidance?</h2>
      <p class="text-blue-100 mb-6">Contact Johnny Watts Agency for a free consultation.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact-us/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
          Contact Us
        </a>
        <a href="/blogs/" class="inline-block px-8 py-3 border-2 border-white text-white font-semibold rounded-md hover:bg-white hover:text-primary transition-colors">
          More Articles
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .prose-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-content :global(p) {
    color: var(--color-gray);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    color: var(--color-gray);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.8;
  }
  .prose-content :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose-content :global(strong) {
    color: var(--color-dark);
  }
</style>
