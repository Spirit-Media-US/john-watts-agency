---
import Layout from './Layout.astro';
import { posts } from '../data/posts';

interface Props {
  title: string;
  description: string;
  date: string;
  img?: string;
}
const { title, description, date, img } = Astro.props;

// Find current post index for prev/next navigation
const currentPath = Astro.url.pathname.replace(/\/$/, '') + '/';
const currentIndex = posts.findIndex(p => p.slug === currentPath);
const prevPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
const nextPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;

// Related posts: pick 2 posts that aren't the current one
const relatedPosts = posts.filter((_, i) => i !== currentIndex).slice(0, 2);
---

<Layout title={`${title} — Johnny Watts Agency`} description={description}>
  <article>
    <!-- Hero -->
    <header class="relative overflow-hidden text-white text-center" style="background: linear-gradient(130deg, #4632DA 0%, #06D9FA 89%); padding-top: 120px; padding-bottom: 160px;">
      <!-- Decorative blobs -->
      <svg class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1440 500" xmlns="http://www.w3.org/2000/svg" style="z-index: 0;">
        <path d="M-50,-50 C100,-30 250,80 280,200 C310,320 200,420 80,440 C-40,460 -120,380 -150,250 C-180,120 -100,-70 -50,-50 Z" fill="rgba(255,255,255,0.07)" />
        <path d="M1200,-50 C1350,0 1480,120 1500,280 C1520,440 1450,550 1320,520 C1190,490 1100,350 1100,200 C1100,50 1150,-50 1200,-50 Z" fill="rgba(255,255,255,0.08)" />
      </svg>
      <div class="relative max-w-3xl mx-auto px-4" style="z-index: 2;">
        <h1 class="mb-4" style="font-family: 'Varela Round', sans-serif; font-size: 40px; font-weight: 300; line-height: 1.2; text-transform: capitalize; color: #ffffff;">{title}</h1>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; color: rgba(255,255,255,0.8);">
          <span>kevin</span>
          <span class="mx-2">·</span>
          <span>{date}</span>
        </p>
      </div>
      <!-- Wave bottom -->
      <div class="absolute bottom-[-1px] left-0 w-full overflow-hidden leading-none" style="z-index: 3; direction: ltr;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" style="display: block; width: calc(100% + 1.3px); position: relative; left: 50%; transform: translateX(-50%) rotate(180deg); height: 100px;">
          <path d="M421.9,6.5c22.6-2.5,51.5,0.4,75.5,5.3c23.6,4.9,70.9,23.5,100.5,35.7c75.8,32.2,133.7,44.5,192.6,49.7c23.6,2.1,48.7,3.5,103.4-2.5c54.7-6,106.2-25.6,106.2-25.6V0H0v30.3c0,0,72,32.6,158.4,30.5c39.2-0.7,92.8-6.7,134-22.4c21.2-8.1,52.2-18.2,79.7-24.2C399.3,7.9,411.6,7.5,421.9,6.5z" fill="#ffffff"/>
        </svg>
      </div>
    </header>

    <!-- Featured Image (overlapping hero) -->
    {img && (
      <div class="relative max-w-3xl mx-auto px-4" style="margin-top: -100px; z-index: 4;">
        <img src={img} alt={title} class="w-full rounded-lg shadow-lg" style="aspect-ratio: 16/9; object-fit: cover;" />
      </div>
    )}

    <!-- Share Bar -->
    <div class="max-w-3xl mx-auto px-4 py-6">
      <div class="flex items-center justify-between border-b border-gray-200 pb-4">
        <p style="font-family: 'Varela Round', sans-serif; font-size: 16px; font-weight: 300; color: #353535;">Share This Post</p>
        <div class="flex items-center gap-4">
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${Astro.url}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full flex items-center justify-center transition-colors" style="background: #f3f4f6; color: #6b7280;" aria-label="Share on Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/></svg>
          </a>
          <button class="share-copy w-9 h-9 rounded-full flex items-center justify-center transition-colors" style="background: #f3f4f6; color: #6b7280; border: none; cursor: pointer;" aria-label="Copy link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </button>
          <a href={`https://twitter.com/intent/tweet?url=${Astro.url}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full flex items-center justify-center transition-colors" style="background: #f3f4f6; color: #6b7280;" aria-label="Share on Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.44 4.83c-.8.37-1.5.38-2.22.02.93-.56.98-.96 1.32-2.02-.88.52-1.86.9-2.9 1.1-.82-.88-2-1.43-3.3-1.43-2.5 0-4.55 2.04-4.55 4.54 0 .36.03.7.1 1.04-3.77-.2-7.12-2-9.36-4.75-.4.67-.6 1.45-.6 2.3 0 1.56.8 2.95 2 3.77-.74-.03-1.44-.23-2.05-.57v.06c0 2.2 1.56 4.03 3.64 4.44-.67.18-1.37.2-2.06.08.58 1.8 2.26 3.12 4.25 3.16C5.78 18.1 3.37 18.74 1 18.46c2 1.3 4.4 2.04 6.97 2.04 8.35 0 12.92-6.92 12.92-12.93 0-.2 0-.4-.02-.6.9-.63 1.96-1.22 2.56-2.14z"/></svg>
          </a>
          <a href={`mailto:?subject=${encodeURIComponent(title)}&body=${Astro.url}`} class="w-9 h-9 rounded-full flex items-center justify-center transition-colors" style="background: #f3f4f6; color: #6b7280;" aria-label="Share via Email">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Blog Content -->
    <div class="pb-12">
      <div class="max-w-3xl mx-auto px-4 prose-content">
        <slot />
      </div>
    </div>

    <!-- Newsletter -->
    <div class="max-w-2xl mx-auto px-4 mb-16">
      <div class="rounded-xl shadow-lg overflow-hidden" style="border-bottom: 4px solid transparent; border-image: linear-gradient(90deg, #4632DA, #06D9FA) 1;">
        <div class="p-8 text-center">
          <h3 class="mb-2" style="font-family: 'Varela Round', sans-serif; font-size: 24px; font-weight: 300; color: #3D4459;">Subscribe To Our Newsletter</h3>
          <p class="mb-6" style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 300; color: #6b7280;">Get updates and learn from the best</p>
          <form class="flex gap-3 max-w-md mx-auto">
            <input
              type="email"
              placeholder="Enter Your Email"
              class="flex-1 px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              style="font-family: 'Montserrat', sans-serif; font-size: 14px;"
            />
            <button type="submit" class="hero-btn inline-flex items-center gap-2 px-6 py-3" style="background-color: #06D9FA; color: #ffffff; font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 500; text-transform: capitalize; border: none; border-radius: 30px; cursor: pointer; white-space: nowrap;">
              Send
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Prev / Next Navigation -->
    <div class="max-w-3xl mx-auto px-4 mb-16">
      <div class="flex justify-between items-start border-t border-gray-200 pt-6">
        {prevPost ? (
          <a href={prevPost.slug} class="group max-w-[45%]" style="text-decoration: none;">
            <span style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 600; color: #4632DA;">Previous</span>
            <p class="mt-1 group-hover:text-primary transition-colors" style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 400; color: #6b7280; line-height: 1.4;">{prevPost.title}</p>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={nextPost.slug} class="group max-w-[45%] text-right ml-auto" style="text-decoration: none;">
            <span style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 600; color: #4632DA;">Next</span>
            <p class="mt-1 group-hover:text-primary transition-colors" style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 400; color: #6b7280; line-height: 1.4;">{nextPost.title}</p>
          </a>
        ) : <div />}
      </div>
    </div>

    <!-- More To Explore -->
    <section class="max-w-4xl mx-auto px-4 mb-16">
      <h2 class="text-center mb-8" style="font-family: 'Varela Round', sans-serif; font-size: 28px; font-weight: 300; color: #3D4459;">More To Explore</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {relatedPosts.map(post => (
          <a href={post.slug} class="block bg-white rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow" style="text-decoration: none;">
            <div class="relative">
              <img src={post.img} alt={post.title} class="w-full h-48 object-cover" loading="lazy" />
              <span class="absolute top-3 left-3 px-3 py-1 text-white text-xs font-medium rounded-full" style="background: #4632DA; font-family: 'Montserrat', sans-serif;">Insurance Expert</span>
            </div>
            <div class="p-5">
              <h3 style="font-family: 'Varela Round', sans-serif; font-size: 18px; font-weight: 300; color: #3D4459; line-height: 1.3; margin-bottom: 8px;">{post.title}</h3>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 300; color: #6b7280; line-height: 1.6; margin-bottom: 12px;">{post.excerpt}</p>
              <div class="flex items-center gap-2" style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #6b7280;">
                <span>kevin</span>
                <span>·</span>
                <span>{post.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </article>

  <!-- CTA Section — sloped gradient band, no whitespace -->
  <div class="relative" style="margin: 0; padding: 0;">
    <!-- The gradient band with clip-path for sloped edges -->
    <div class="relative overflow-visible" style="background: linear-gradient(100deg, #4632DA 0%, #2a7de8 40%, #06D9FA 100%); clip-path: polygon(0 15%, 100% 0, 100% 85%, 0 100%); padding: 100px 0 80px;">
      <!-- Decorative blob — left -->
      <svg class="absolute pointer-events-none" style="left: -60px; top: 0; width: 200px; height: 100%; opacity: 0.45;" viewBox="0 0 200 400" xmlns="http://www.w3.org/2000/svg">
        <path d="M80,-30 C170,10 220,130 190,250 C160,370 60,380 0,300 C-60,220 -50,80 10,10 C40,-20 50,-40 80,-30 Z" fill="rgba(70,50,218,0.6)" />
      </svg>
      <!-- Decorative blob — right -->
      <svg class="absolute pointer-events-none" style="right: -40px; bottom: 0; width: 180px; height: 60%; opacity: 0.35;" viewBox="0 0 180 250" xmlns="http://www.w3.org/2000/svg">
        <path d="M120,-20 C180,20 220,100 190,180 C160,260 80,280 30,230 C-20,180 -10,80 40,20 C70,-10 90,-35 120,-20 Z" fill="rgba(6,217,250,0.5)" />
      </svg>

      <div class="relative max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row items-center gap-8" style="z-index: 2;">
        <!-- Text -->
        <div class="md:w-[45%] text-white">
          <h2 class="mb-3" style="font-family: 'Varela Round', sans-serif; font-size: 36px; font-weight: 300; color: #ffffff; font-style: italic; line-height: 1.2;">Do You Want To Boost Your Business?</h2>
          <p class="mb-6" style="font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.85); font-style: italic;">Drop Us A Line And Keep In Touch</p>
          <a href="/contact-us/" class="inline-flex items-center gap-2 px-7 py-3 transition-all hover:shadow-lg" style="background-color: #ffffff; color: #06D9FA; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 500; text-transform: capitalize; text-decoration: none; border-radius: 30px;">
            Contact Us
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
          </a>
        </div>
        <!-- Image -->
        <div class="md:w-[55%] flex justify-end">
          <img
            src="https://cdn.sanity.io/images/ssbenczy/production/17f6656e1958d23ff03f1d52889993476f1cb7e0-1024x683.jpg?w=550&auto=format"
            alt="Johnny Watts Agency team"
            class="shadow-xl"
            style="border-radius: 30px; width: 100%; max-width: 480px; object-fit: cover;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>

  <script>
    document.querySelector('.share-copy')?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href);
      const btn = document.querySelector('.share-copy') as HTMLElement;
      btn.style.background = '#4632DA';
      btn.style.color = '#fff';
      setTimeout(() => { btn.style.background = '#f3f4f6'; btn.style.color = '#6b7280'; }, 1500);
    });
  </script>
</Layout>

<style>
  .prose-content :global(h2) {
    font-family: 'Varela Round', sans-serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: #3D4459;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content :global(h3) {
    font-family: 'Varela Round', sans-serif;
    font-size: 1.25rem;
    font-weight: 300;
    color: #3D4459;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-content :global(p) {
    font-family: 'Montserrat', sans-serif;
    color: #353535;
    font-weight: 300;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    color: #353535;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.8;
  }
  .prose-content :global(li) {
    margin-bottom: 0.5rem;
    font-weight: 300;
  }
  .prose-content :global(strong) {
    color: #353535;
    font-weight: 600;
  }
  .prose-content :global(a) {
    color: #4632DA;
    text-decoration: underline;
  }
  .prose-content :global(a:hover) {
    color: #3526b0;
  }
  .prose-content :global(img) {
    width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

</style>
