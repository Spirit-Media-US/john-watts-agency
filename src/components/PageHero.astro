---
interface Props {
  title: string;
  subtitle?: string;
  waveFill?: string;
}
const { title, subtitle, waveFill = '#ffffff' } = Astro.props;
---

<section class="relative overflow-hidden text-white text-center bg-gradient-hero padding-hero">
  <!-- Decorative blob shapes — one left, one right -->
  <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1440 500" xmlns="http://www.w3.org/2000/svg">
    <!-- Left blob -->
    <path d="M-50,-50 C100,-30 250,80 280,200 C310,320 200,420 80,440 C-40,460 -120,380 -150,250 C-180,120 -100,-70 -50,-50 Z" fill="rgba(255,255,255,0.07)" />
    <!-- Right blob -->
    <path d="M1200,-50 C1350,0 1480,120 1500,280 C1520,440 1450,550 1320,520 C1190,490 1100,350 1100,200 C1100,50 1150,-50 1200,-50 Z" fill="rgba(255,255,255,0.08)" />
  </svg>

  <div class="relative z-[2] max-w-[1250px] mx-auto px-[2%] pt-[30px] pb-[30px]">
    <h1 class="font-heading font-light leading-[1.2] capitalize text-white text-clamp-hero">{title}</h1>
    {subtitle && <p class="mt-4 font-light text-white/90 text-clamp-subtitle">{subtitle}</p>}
  </div>

  <!-- Wave bottom (exact WP Elementor technique: slightly wider SVG, centered, rotated) -->
  <div class="absolute bottom-[-1px] left-0 w-full overflow-hidden leading-none z-[3] dir-ltr">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" class="wave-svg">
      <path d="M0,40 C167,80 333,0 500,40 C667,80 833,0 1000,40 L1000,0 L0,0 Z" fill={waveFill}/>
    </svg>
  </div>
</section>
