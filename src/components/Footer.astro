---
import { sanityClient, urlFor } from '../lib/sanity';
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{ footerLogo, logo }`);
const footerLogoUrl = settings?.footerLogo ? urlFor(settings.footerLogo).height(80).auto('format').url() : settings?.logo ? urlFor(settings.logo).height(80).auto('format').url() : '/jwatts2.jpg';
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/medicare/' },
  { label: 'Blogs', href: '/blogs/' },
  { label: 'About', href: '/about/' },
  { label: 'Get a Quote', href: '/life-quote/' },
  { label: 'Contact Us', href: '/contact-us/' },
  { label: 'Disclaimer', href: '/disclaimer/' },
];
---

<footer>
  <!-- Main footer -->
  <div style="background: #ffffff;" class="text-secondary">
    <div class="max-w-[1250px] mx-auto px-4 py-10">
      <!-- Top row: logo + nav links -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-8">
        <a href="/" aria-label="Johnny Watts Agency — Home">
          <img src={footerLogoUrl} alt="Johnny Watts Agency" width="200" height="83" class="h-20 w-auto" />
        </a>
        <ul class="flex flex-wrap justify-center gap-4 text-sm">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="transition-colors inline-flex items-center min-h-[48px] px-3" style="font-family: 'Varela Round', sans-serif; font-size: 15px; font-weight: 400; color: #353535;" onmouseover="this.style.color='#4632DA'" onmouseout="this.style.color='#353535'">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Bottom row: social + copyright -->
      <div class="border-t border-gray-200 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm" style="color: #353535;">
        <div class="flex items-center gap-3">
          <span style="font-weight: 400;">Follow Us:</span>
          <a href="https://www.facebook.com/johnnywatts/" target="_blank" rel="noopener noreferrer" class="transition-colors p-2 inline-flex" style="color: #353535;" aria-label="Facebook">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/johnny-watts-687b1719" target="_blank" rel="noopener noreferrer" class="transition-colors p-2 inline-flex" style="color: #353535;" aria-label="LinkedIn">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="bg-white py-3">
    <div class="max-w-[1250px] mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-sm" style="font-family: 'Varela Round', sans-serif; color: #3D4459;">
      <p>&copy; 2026 Johnny Watts Agency. All rights reserved.</p>
      <p>Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener noreferrer" style="color: #D32A2B; font-weight: 700;">Spirit Media</a></p>
    </div>
  </div>
</footer>
