---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Medicare', href: '/medicare/' },
  { label: 'Health Insurance Marketplace', href: '/health-insurance-marketplace/' },
  { label: 'Life Insurance', href: '/learn-about-life-insurance/' },
  { label: 'Blog', href: '/blogs/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact Us', href: '/contact-us/' },
  { label: 'Disclaimer', href: '/disclaimer/' },
];
---

<footer class="bg-dark text-white">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-xl font-bold text-white mb-3 font-serif">Johnny Watts Agency</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Your trusted insurance specialists serving families and individuals for over 40 years.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-3">Quick Links</h4>
        <ul class="flex flex-col gap-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-3">Contact</h4>
        <ul class="flex flex-col gap-2 text-sm text-gray-300">
          <li>
            <a href="tel:8286354200" class="hover:text-white transition-colors">
              📞 (828) 635-4200
            </a>
          </li>
          <li>
            <a href="mailto:johnny@johnnywattsagency.com" class="hover:text-white transition-colors">
              ✉️ johnny@johnnywattsagency.com
            </a>
          </li>
          <li>📍 351 NC Hwy 16 S, Taylorsville, NC 28681</li>
          <li>🕐 Mon–Fri 9:30 AM – 5:00 PM</li>
        </ul>

        <!-- Social -->
        <div class="flex gap-4 mt-4">
          <a href="https://www.facebook.com/johnnywatts/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/johnny-watts-687b1719" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-600 mt-8 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-gray-400">
      <p>&copy; {currentYear} Johnny Watts Agency. All Rights Reserved.</p>
      <p>
        Design by <a href="https://spiritmedia.us" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Spirit Media</a>
      </p>
    </div>
  </div>
</footer>
