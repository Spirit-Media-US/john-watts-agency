---
const currentPath = Astro.url.pathname;

const services = [
  { label: 'Medicare', href: '/medicare/' },
  { label: 'Health Insurance Marketplace', href: '/health-insurance-marketplace/' },
  { label: 'Life Insurance', href: '/learn-about-life-insurance/' },
];

const quotes = [
  { label: 'Medicare Quote', href: '/medicare-quote/' },
  { label: 'Life Quote', href: '/life-quote/' },
  { label: 'Health Marketplace Quote', href: '/health-insurance-marketplace-services-quote/' },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href.slice(0, -1);
}
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <!-- Top bar: phone -->
  <div class="bg-dark text-white text-sm py-2">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
      <span class="hidden sm:inline">Your Trusted Insurance Specialists</span>
      <a href="tel:8286354200" class="text-white hover:text-primary-light font-semibold">
        📞 (828) 635-4200
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo / Brand -->
      <a href="/" class="text-xl font-bold text-dark hover:text-primary font-serif">
        Johnny Watts Agency
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-toggle"
        class="lg:hidden p-2 rounded-md text-dark hover:bg-gray-light"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-1">
        <li>
          <a href="/" class:list={['nav-link', { active: isActive('/') }]}>Home</a>
        </li>

        <!-- Services dropdown -->
        <li class="relative group">
          <button class="nav-link flex items-center gap-1" aria-haspopup="true">
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul class="absolute left-0 top-full mt-1 w-64 bg-white shadow-lg rounded-md py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {services.map(s => (
              <li>
                <a href={s.href} class:list={['block px-4 py-2 text-sm text-dark hover:bg-gray-light hover:text-primary', { 'text-primary font-semibold': isActive(s.href) }]}>
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </li>

        <li>
          <a href="/blogs/" class:list={['nav-link', { active: isActive('/blogs/') }]}>Blog</a>
        </li>
        <li>
          <a href="/about/" class:list={['nav-link', { active: isActive('/about/') }]}>About</a>
        </li>

        <!-- Get a Quote dropdown -->
        <li class="relative group">
          <button class="nav-link flex items-center gap-1" aria-haspopup="true">
            Get a Quote
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul class="absolute left-0 top-full mt-1 w-64 bg-white shadow-lg rounded-md py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {quotes.map(q => (
              <li>
                <a href={q.href} class:list={['block px-4 py-2 text-sm text-dark hover:bg-gray-light hover:text-primary', { 'text-primary font-semibold': isActive(q.href) }]}>
                  {q.label}
                </a>
              </li>
            ))}
          </ul>
        </li>

        <li>
          <a href="/contact-us/" class="inline-block px-5 py-2 bg-primary text-white rounded-md font-semibold hover:bg-primary-dark transition-colors">
            Contact Us
          </a>
        </li>
      </ul>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-gray-light pt-4">
      <ul class="flex flex-col gap-2">
        <li><a href="/" class:list={['mobile-link', { active: isActive('/') }]}>Home</a></li>

        <!-- Mobile Services -->
        <li>
          <button class="mobile-link w-full flex justify-between items-center mobile-accordion-toggle" data-target="mobile-services">
            Services
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul id="mobile-services" class="hidden pl-4 mt-1 flex flex-col gap-1">
            {services.map(s => (
              <li><a href={s.href} class="mobile-link text-sm">{s.label}</a></li>
            ))}
          </ul>
        </li>

        <li><a href="/blogs/" class:list={['mobile-link', { active: isActive('/blogs/') }]}>Blog</a></li>
        <li><a href="/about/" class:list={['mobile-link', { active: isActive('/about/') }]}>About</a></li>

        <!-- Mobile Quotes -->
        <li>
          <button class="mobile-link w-full flex justify-between items-center mobile-accordion-toggle" data-target="mobile-quotes">
            Get a Quote
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul id="mobile-quotes" class="hidden pl-4 mt-1 flex flex-col gap-1">
            {quotes.map(q => (
              <li><a href={q.href} class="mobile-link text-sm">{q.label}</a></li>
            ))}
          </ul>
        </li>

        <li>
          <a href="/contact-us/" class="inline-block w-full text-center px-5 py-2 bg-primary text-white rounded-md font-semibold hover:bg-primary-dark transition-colors">
            Contact Us
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  .nav-link {
    display: inline-block;
    padding: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-dark);
    border-radius: 0.375rem;
    transition: color 0.2s, background-color 0.2s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
    background-color: var(--color-gray-light);
  }
  .mobile-link {
    display: block;
    padding: 0.625rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-dark);
    border-radius: 0.375rem;
    transition: background-color 0.2s;
  }
  .mobile-link:hover,
  .mobile-link.active {
    background-color: var(--color-gray-light);
    color: var(--color-primary);
  }
</style>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!menu?.classList.contains('hidden')));
  });

  document.querySelectorAll('.mobile-accordion-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      target?.classList.toggle('hidden');
      const svg = btn.querySelector('svg');
      svg?.classList.toggle('rotate-180');
    });
  });
</script>
