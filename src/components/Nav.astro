---
const currentPath = Astro.url.pathname;

const services = [
  { label: 'Medicare', href: '/medicare/' },
  { label: 'Health Insurance Marketplace', href: '/health-insurance-marketplace/' },
  { label: 'Life Insurance', href: '/learn-about-life-insurance/' },
];

const quotes = [
  { label: 'Medicare Quote', href: '/medicare-quote/' },
  { label: 'Life Quote', href: '/life-quote/' },
  { label: 'Health Marketplace Quote', href: '/health-insurance-marketplace-services-quote/' },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href.slice(0, -1);
}
---

<header class="nav-header sticky top-0 z-50" style="background: linear-gradient(130deg, #4632DA 0%, #06D9FA 100%); margin-bottom: -60px;">
  <nav class="max-w-[1250px] mx-auto px-[2%] h-[90px] flex items-center">
    <div class="flex items-center justify-between w-full">
      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0" style="width: 20%;">
        <img src="https://johnnywattsagency.com/wp-content/uploads/2023/10/johnwatts-logo-edited-2048x852.png" alt="Johnny Watts Agency" class="w-[70%] h-auto" />
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-toggle"
        class="lg:hidden p-2 rounded-md text-white hover:bg-white/20"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-0">
        <li>
          <a href="/" class:list={['nav-link', { active: isActive('/') }]}>Home</a>
        </li>

        <!-- Services dropdown -->
        <li class="relative group">
          <button class="nav-link !inline-flex items-center gap-1" aria-haspopup="true">
            Services
            <svg class="w-3 h-3 shrink-0 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul class="absolute left-0 top-full mt-0 w-64 bg-white shadow-lg rounded-md py-0 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {services.map(s => (
              <li class="border-b border-gray-100 last:border-0">
                <a href={s.href} class:list={['block px-4 py-[15px] text-[15px] font-light text-secondary hover:text-primary capitalize', { 'text-primary font-medium': isActive(s.href) }]}>
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </li>

        <li>
          <a href="/blogs/" class:list={['nav-link', { active: isActive('/blogs/') }]}>Blogs</a>
        </li>
        <li>
          <a href="/about/" class:list={['nav-link', { active: isActive('/about/') }]}>About</a>
        </li>

        <!-- Get a Quote dropdown -->
        <li class="relative group">
          <button class="nav-link !inline-flex items-center gap-1" aria-haspopup="true">
            Get a Quote
            <svg class="w-3 h-3 shrink-0 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul class="absolute left-0 top-full mt-0 w-64 bg-white shadow-lg rounded-md py-0 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {quotes.map(q => (
              <li class="border-b border-gray-100 last:border-0">
                <a href={q.href} class:list={['block px-4 py-[15px] text-[15px] font-light text-secondary hover:text-primary capitalize', { 'text-primary font-medium': isActive(q.href) }]}>
                  {q.label}
                </a>
              </li>
            ))}
          </ul>
        </li>

        <li>
          <a href="/contact-us/" class:list={['nav-link', { active: isActive('/contact-us/') }]}>Contact Us</a>
        </li>

        <!-- Phone -->
        <li class="ml-4 pl-4 border-l border-white/70">
          <a href="tel:8286354200" class="flex items-center gap-2 text-white font-bold text-[15px] capitalize hover:text-white/80">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            828-635-4200
          </a>
        </li>
      </ul>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden absolute left-0 top-full w-full bg-white shadow-lg">
      <ul class="flex flex-col py-4">
        <li><a href="/" class:list={['mobile-link', { active: isActive('/') }]}>Home</a></li>
        <li>
          <button class="mobile-link w-full flex justify-between items-center mobile-accordion-toggle" data-target="mobile-services">
            Services
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul id="mobile-services" class="hidden pl-4 flex flex-col">
            {services.map(s => (
              <li><a href={s.href} class="mobile-link text-sm">{s.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href="/blogs/" class:list={['mobile-link', { active: isActive('/blogs/') }]}>Blogs</a></li>
        <li><a href="/about/" class:list={['mobile-link', { active: isActive('/about/') }]}>About</a></li>
        <li>
          <button class="mobile-link w-full flex justify-between items-center mobile-accordion-toggle" data-target="mobile-quotes">
            Get a Quote
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul id="mobile-quotes" class="hidden pl-4 flex flex-col">
            {quotes.map(q => (
              <li><a href={q.href} class="mobile-link text-sm">{q.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href="/contact-us/" class:list={['mobile-link', { active: isActive('/contact-us/') }]}>Contact Us</a></li>
        <li class="pt-2 mx-4 border-t border-gray-200">
          <a href="tel:8286354200" class="flex items-center gap-2 text-primary font-bold py-3">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            828-635-4200
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  .nav-header {
    box-shadow: 0px 10px 20px 0px rgba(0,0,0,0.1);
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 35px 25px;
    white-space: nowrap;
    font-family: "Varela Round", sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: #FFFEFE;
    transition: color 0.2s;
    text-decoration: none;
    text-transform: capitalize;
  }
  .nav-link:hover,
  .nav-link.active {
    color: #FFFEFE;
  }
  /* Underline animation on hover */
  .nav-link::after {
    content: '';
    display: block;
    width: 0;
    height: 2px;
    background: #FFFEFE;
    transition: width 0.3s;
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  .mobile-link {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: "Montserrat", sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--color-secondary, #3D4459);
    transition: background-color 0.2s;
  }
  .mobile-link:hover,
  .mobile-link.active {
    background-color: #f3f4f6;
    color: var(--color-primary, #4632DA);
  }
</style>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!menu?.classList.contains('hidden')));
  });

  document.querySelectorAll('.mobile-accordion-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      target?.classList.toggle('hidden');
      const svg = btn.querySelector('svg');
      svg?.classList.toggle('rotate-180');
    });
  });
</script>
