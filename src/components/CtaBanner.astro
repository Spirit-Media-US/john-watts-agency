---
interface Props {
  heading?: string;
  buttonText?: string;
  buttonHref?: string;
  waveFill?: string;
}
const {
  heading = 'Secure Your Future Today!',
  buttonText = 'Life Quote',
  buttonHref = '/life-quote/',
  waveFill = '#ffffff',
} = Astro.props;
---

<section class="relative overflow-hidden animate-gradient pt-20 pb-[60px] -mt-px bg-gradient-animate">
  <!-- Wave top -->
  <div class="absolute top-[-1px] left-0 w-full overflow-hidden leading-none z-[2]">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" class="wave-svg-cta">
      <path d="M0,40 C167,80 333,0 500,40 C667,80 833,0 1000,40 L1000,0 L0,0 Z" fill={waveFill}/>
    </svg>
  </div>
  <!-- Decorative circles -->
  <div class="absolute top-[-40px] left-[-40px] w-[200px] h-[200px] rounded-full pointer-events-none animate-pulse-soft bg-white/10"></div>
  <div class="absolute bottom-[-50px] right-[-50px] w-[250px] h-[250px] rounded-full pointer-events-none animate-float bg-white/[0.08]"></div>
  <div class="relative max-w-7xl mx-auto px-4 text-left z-[3]">
    <h2 class="mb-6 font-heading font-light text-white text-clamp-section" data-aos="fade-up">{heading}</h2>
    <a href={buttonHref} class="btn-shine inline-flex items-center gap-2 px-8 py-3.5 transition-all hover:shadow-lg bg-white text-accent text-base font-medium capitalize no-underline rounded-full" data-aos="fade-up" data-aos-delay="200">
      {buttonText}
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 44 448 424"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
    </a>
  </div>
</section>
