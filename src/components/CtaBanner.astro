---
interface Props {
  heading?: string;
  buttonText?: string;
  buttonHref?: string;
  waveFill?: string;
}
const {
  heading = 'Secure Your Future Today!',
  buttonText = 'Life Quote',
  buttonHref = '/life-quote/',
  waveFill = '#ffffff',
} = Astro.props;
---

<section class="relative overflow-hidden animate-gradient pt-20 pb-[60px] -mt-px" style="background: linear-gradient(130deg, #4632DA 0%, #2a7de8 33%, #06D9FA 66%, #4632DA 100%); background-size: 200% 200%;">
  <!-- Wave top -->
  <div class="absolute top-[-1px] left-0 w-full overflow-hidden leading-none z-[2]">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" style="display: block; width: calc(250% + 100.3px); position: relative; left: 50%; transform: translateX(-50%) scaleX(-1); height: 60px;">
      <path d="M421.9,6.5c22.6-2.5,51.5,0.4,75.5,5.3c23.6,4.9,70.9,23.5,100.5,35.7c75.8,32.2,133.7,44.5,192.6,49.7c23.6,2.1,48.7,3.5,103.4-2.5c54.7-6,106.2-25.6,106.2-25.6V0H0v30.3c0,0,72,32.6,158.4,30.5c39.2-0.7,92.8-6.7,134-22.4c21.2-8.1,52.2-18.2,79.7-24.2C399.3,7.9,411.6,7.5,421.9,6.5z" fill={waveFill}/>
    </svg>
  </div>
  <!-- Decorative circles -->
  <div class="absolute top-[-40px] left-[-40px] w-[200px] h-[200px] rounded-full pointer-events-none animate-pulse-soft bg-white/10"></div>
  <div class="absolute bottom-[-50px] right-[-50px] w-[250px] h-[250px] rounded-full pointer-events-none animate-float bg-white/[0.08]"></div>
  <div class="relative max-w-7xl mx-auto px-4 text-left z-[3]">
    <h2 class="mb-6 font-heading font-light text-white" data-aos="fade-up" style="font-size: clamp(24px, 4vw, 36px);">{heading}</h2>
    <a href={buttonHref} class="btn-shine inline-flex items-center gap-2 px-8 py-3.5 transition-all hover:shadow-lg bg-white text-accent text-base font-medium capitalize no-underline rounded-full" data-aos="fade-up" data-aos-delay="200">
      {buttonText}
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
    </a>
  </div>
</section>
