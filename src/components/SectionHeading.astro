---
interface Props {
  title: string;
  subtitle?: string;
  kicker?: string;
}
const { title, subtitle, kicker } = Astro.props;
---

<div class="text-center mb-10">
  {kicker && <p class="text-sm uppercase tracking-widest text-gray mb-2">{kicker}</p>}
  <h2 class="text-secondary">{title}</h2>
  {subtitle && <p class="mt-3 text-gray max-w-2xl mx-auto">{subtitle}</p>}
</div>
