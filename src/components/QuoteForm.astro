---
interface Props {
  heading: string;
  description?: string;
}
const { heading, description = 'Please complete the form below and one of our agents will be in touch shortly.' } = Astro.props;
---

<section class="py-16 bg-gray-light">
  <div class="max-w-xl mx-auto px-4">
    <h1 class="text-center mb-4">{heading}</h1>
    <p class="text-center text-gray mb-8">{description}</p>

    <form class="bg-white rounded-lg shadow-md p-8 flex flex-col gap-4">
      <div>
        <label for="name" class="block text-sm font-medium text-dark mb-1">Full Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="Your full name"
        />
      </div>
      <div>
        <label for="phone" class="block text-sm font-medium text-dark mb-1">Phone</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="(000) 000-0000"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-dark mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="you@example.com"
        />
      </div>
      <button
        type="submit"
        class="w-full py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary-dark transition-colors mt-2"
      >
        Send
      </button>
    </form>
  </div>
</section>
