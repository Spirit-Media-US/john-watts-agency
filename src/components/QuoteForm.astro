---
interface Props {
  heading?: string;
  description?: string;
  formName?: string;
}
const { heading, description, formName = 'contact' } = Astro.props;
---

{heading && <h1 class="text-center mb-4 text-secondary">{heading}</h1>}
{description && <p class="text-center text-gray mb-8">{description}</p>}

<form class="bg-white rounded-lg shadow-md p-8 flex flex-col gap-4" method="POST" data-netlify="true" name={formName}>
  <input type="hidden" name="form-name" value={formName} />
  <div>
    <label for="name" class="block text-sm font-medium text-dark mb-1">Full Name</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="Your full name"
    />
  </div>
  <div>
    <label for="phone" class="block text-sm font-medium text-dark mb-1">Phone</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      required
      class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="(000) 000-0000"
    />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-dark mb-1">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="you@example.com"
    />
  </div>
  <button
    type="submit"
    class="hero-btn w-full mt-2 inline-flex items-center justify-center gap-2 bg-accent text-white text-base font-medium capitalize border-none rounded-full px-7 py-3 cursor-pointer"
  >
    Send
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
  </button>
</form>
