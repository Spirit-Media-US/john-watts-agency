---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Medicare — Johnny Watts Agency" description="Learn about Medicare options with Johnny Watts Agency. Expert guidance for Medicare coverage in North Carolina.">

  <section class="bg-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-3">Medicare</h1>
      <p class="text-gray-300 text-lg">Expert guidance through your Medicare options</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 prose prose-lg">
      <!-- Medicare content will be migrated from existing site in Phase 3 -->
      <p class="text-gray">
        Medicare content will be added during the content migration phase. This page will cover Medicare basics, enrollment periods, and how Johnny Watts Agency can help you find the right coverage.
      </p>
    </div>
  </section>

  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Ready to Explore Your Medicare Options?</h2>
      <a href="/medicare-quote/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
        Get a Medicare Quote
      </a>
    </div>
  </section>

</Layout>
