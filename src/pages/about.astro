---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const mainTeam = [
  { name: 'Johnny Watts', role: 'Owner / Agent', email: 'johnny@johnnywattsagency.com' },
  { name: 'Donnie Bost', role: 'Agent', email: 'donnie@johnnywattsagency.com' },
  { name: 'Linsey Stuckey', role: 'Agent', email: 'linsey@johnnywattsagency.com' },
  { name: 'Tiffany Billey', role: 'Agent', email: 'tiffany@johnnywattsagency.com' },
];

const supportTeam = [
  'Kyle Russell',
  'Jim Harmon',
  'Diane McCoy',
  'Pam Watts',
  'Leigh Anne Burke',
];
---

<Layout title="About Us — Johnny Watts Agency" description="Meet the team at Johnny Watts Agency. Over 40 years of trusted insurance service in Taylorsville, NC.">

  <!-- Header -->
  <section class="bg-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-3">About Us</h1>
      <p class="text-gray-300 text-lg">Behind the scenes at Johnny Watts Agency</p>
    </div>
  </section>

  <!-- Main Team -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Our Team" subtitle="Dedicated professionals who treat you like family." />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {mainTeam.map(member => (
          <div class="flex flex-col sm:flex-row gap-6 bg-gray-light rounded-lg p-6">
            <!-- Headshot placeholder — will be replaced with Sanity images -->
            <div class="w-32 h-32 shrink-0 bg-gray-300 rounded-lg mx-auto sm:mx-0"></div>
            <div>
              <h3 class="mb-1">{member.name}</h3>
              <p class="text-primary font-medium mb-2">{member.role}</p>
              <p class="text-gray text-sm mb-2">Bio will be loaded from Sanity CMS.</p>
              <a href={`mailto:${member.email}`} class="text-sm text-primary hover:text-primary-dark">
                {member.email}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support Team -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Extended Team" />
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {supportTeam.map(name => (
          <div class="bg-white rounded-lg p-4 text-center">
            <div class="w-16 h-16 mx-auto mb-3 bg-gray-300 rounded-full"></div>
            <p class="font-medium text-sm">{name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Our Partners" subtitle="We work with the nation's top insurance carriers." />
      <div class="text-center text-gray text-sm italic">
        Partner logos coming soon.
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Get a Life Insurance Quote</h2>
      <a href="/life-quote/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
        Get a Quote
      </a>
    </div>
  </section>

</Layout>
