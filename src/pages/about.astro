---

<Layout title="About Us — Johnny Watts Agency" description="Meet the team at Johnny Watts Agency. Over 40 years of trusted insurance service in Taylorsville, NC.">

  <!-- Hero Banner -->
  <section class="relative text-white py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-dark"></div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <p class="text-sm uppercase tracking-widest text-gray-400 mb-2">behind the scenes at beyond</p>
      <h1 class="text-white">About Us</h1>
    </div>
  </section>

  <!-- Main Team — full bios -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex flex-col gap-12">
        {mainTeam.map(member => (
          <div class="flex flex-col md:flex-row gap-8 items-start">
            <img
              src={`${member.img}?w=300&h=300&fit=crop&auto=format`}
              alt={member.name}
              class="w-48 h-48 shrink-0 rounded-lg object-cover mx-auto md:mx-0"
              loading="lazy"
            />
            <div>
              <h3 class="mb-1">{member.name}</h3>
              <p class="text-primary font-medium mb-4">{member.role}</p>
              <p class="text-gray leading-relaxed mb-4">{member.bio}</p>
              <a href={`mailto:${member.email}`} class="btn" style="font-size:0.9375rem;">
                Email {member.name.split(' ')[0]}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support Team -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-5xl mx-auto px-4">
      <SectionHeading title="Our Team" />
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
        {supportTeam.map(person => (
          <div class="bg-white rounded-lg p-5 text-center">
            <img src={`${person.img}?w=160&h=160&fit=crop&auto=format`} alt={person.name} class="w-20 h-20 mx-auto mb-3 rounded-full object-cover" loading="lazy" />
            <p class="font-semibold">{person.name}</p>
            <p class="text-sm text-gray">{person.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company Affiliation -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <SectionHeading kicker="we work with them" title="Company Affiliation" subtitle="The following are just a few of the over 40 top insurance companies we access to compare their rates to find the best plan to fit your needs." />
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-6 items-center justify-items-center max-w-4xl mx-auto">
        {partners.map(p => (
          <img src={p.url} alt={p.name} class="h-12 md:h-16 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <a href="/life-quote/" class="btn">
        Life Quote
      </a>
    </div>
  </section>

</Layout>
