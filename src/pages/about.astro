---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageHero from '../components/PageHero.astro';
import MailtoLink from '../components/MailtoLink.astro';
import { sanityClient, urlFor } from '../lib/sanity';

// Fetch team from Sanity
const allTeam = await sanityClient.fetch(`*[_type == "teamMember"] | order(order asc) { name, role, email, bio, featured, headshot }`);
const mainTeam = allTeam.filter((t: any) => t.featured).map((t: any) => {
  const email = t.email || '';
  const [emailUser = '', emailDomain = ''] = email.includes('@') ? email.split('@') : ['', ''];
  return {
    name: t.name,
    role: t.role,
    emailUser,
    emailDomain,
    img: t.headshot ? urlFor(t.headshot).width(400).height(400).fit('crop').auto('format').url() : '',
    bio: (t.bio || '').split('\n').filter((p: string) => p.trim()),
  };
});
const supportTeam = allTeam.filter((t: any) => !t.featured).map((t: any) => ({
  name: t.name,
  role: t.role,
  img: t.headshot ? urlFor(t.headshot).width(250).auto('format').url() : '',
}));

// Fetch partners from Sanity
const partners = (await sanityClient.fetch(`*[_type == "partner"] | order(name asc) { name, logo }`)).map((p: any) => ({
  name: p.name,
  url: p.logo ? urlFor(p.logo).height(65).auto('format').url() : '',
}));
---

<Layout title="About Us — Meet the Johnny Watts Agency Team | Taylorsville, NC" description="Meet the licensed insurance professionals at Johnny Watts Agency. Serving North Carolina families with Medicare, health, and life insurance since 1984.">

  <PageHero title="About Us" subtitle="Behind The Scenes At Johnny Watts Agency" />

  <!-- Main Team — full bios (matching WP Elementor layout) -->
  <section class="py-16 md:py-24">
    <div class="max-w-[1100px] mx-auto px-4">
      <div class="flex flex-col gap-20">
        {mainTeam.map((member, i) => (
          <div class="relative flex flex-col md:flex-row gap-10 items-start " data-aos="fade-up">
            <!-- Photo -->
            <div class="relative shrink-0 mx-auto md:mx-0">
              <img
                src={member.img}
                alt={member.name}
                class="relative w-[180px] h-[180px] md:w-[250px] md:h-[250px] object-cover object-top bg-white blob-shape-1"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                width="250"
                height="250"
              />
            </div>
            <!-- Bio content -->
            <div class="flex-1">
              <h2 class="font-heading text-[2rem] font-light text-primary mb-1">{member.name}</h2>
              <p class="text-[15px] font-normal text-gray mb-5">{member.role}</p>
              {member.bio.map(paragraph => (
                <p class="text-[15px] font-light leading-[1.6] text-dark mb-3">{paragraph}</p>
              ))}
              {member.emailUser && member.emailDomain && (
                <MailtoLink user={member.emailUser} domain={member.emailDomain} label={`Email ${member.name}`} class="hero-btn inline-flex items-center gap-2 px-7 py-3 mt-4 bg-primary text-white text-[15px] font-medium capitalize no-underline rounded-full">
                  Email {member.name}
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
                </MailtoLink>
              )}
            </div>
            <!-- Decorative circle on right (faint) -->
            <div class="hidden md:block absolute -right-8 top-1/2 -translate-y-1/2 w-[160px] h-[160px] rounded-full pointer-events-none bg-[rgba(6,217,250,0.06)]"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support Team Grid -->
  <section class="py-16 md:py-20 bg-[#f9f9f9]">
    <div class="max-w-[1100px] mx-auto px-4">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
        {supportTeam.map(person => (
          <div class="text-center " data-aos="zoom-in">
            <img src={person.img} alt={person.name} class="w-[150px] h-[150px] mx-auto mb-3 rounded-full object-cover object-top bg-white hover-tilt shadow-[0_10px_30px_rgba(0,0,0,0.15)]" loading="lazy" decoding="async" width="150" height="150" />
            <h3 class="font-heading text-base font-normal text-dark">{person.name}</h3>
            <p class="text-sm font-normal text-gray">{person.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company Affiliation — infinite logo carousel -->
  <section class="py-16 md:py-20">
    <div class="max-w-[1100px] mx-auto px-4">
      <SectionHeading kicker="we work with them" title="Company Affiliation" subtitle="The following are just a few of the over 40 top insurance companies we access to compare their rates to find the best plan to fit your needs." />
      <div class="about-logo-slider overflow-hidden relative mask-fade-x">
        <div class="about-logo-track flex items-center gap-6 md:gap-16" id="about-logo-track">
          {partners.map(p => (
            <img src={p.url} alt={p.name} class="h-12 md:h-16 w-auto object-contain shrink-0" loading="lazy" decoding="async" width="120" height="64" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes about-logo-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .about-logo-track {
      animation: about-logo-scroll 30s linear infinite;
      width: max-content;
    }
    .about-logo-track:hover {
      animation-play-state: paused;
    }
  </style>

  <script>
    const aboutTrack = document.getElementById('about-logo-track');
    if (aboutTrack) {
      aboutTrack.innerHTML += aboutTrack.innerHTML;
    }
  </script>

  <!-- CTA — Get A Life Insurance Quote -->
  <section class="py-16 text-center bg-[#f9f9f9]">
    <div class="max-w-3xl mx-auto px-4">
      <a href="/life-quote/" class="hero-btn inline-flex items-center gap-2 px-8 py-4 bg-primary text-white text-base font-medium capitalize no-underline rounded-full">
        Get A Life Insurance Quote
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
      </a>
    </div>
  </section>

  <CtaBanner />

</Layout>
