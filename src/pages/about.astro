---

<Layout title="About Us — Johnny Watts Agency" description="Meet the team at Johnny Watts Agency. Over 40 years of trusted insurance service in Taylorsville, NC.">

  <PageHero title="About Us" subtitle="Behind The Scenes At Beyond" />

  <!-- Main Team — full bios (matching WP Elementor layout) -->
  <section class="py-16 md:py-24">
    <div class="max-w-[1100px] mx-auto px-4">
      <div class="flex flex-col gap-20">
        {mainTeam.map((member, i) => (
          <div class="relative flex flex-col md:flex-row gap-10 items-start">
            <!-- Decorative circle behind photo -->
            <div class="relative shrink-0 mx-auto md:mx-0">
              <div class="absolute -top-4 -left-4 w-[220px] h-[220px] rounded-full pointer-events-none" style="background: rgba(70,50,218,0.08);"></div>
              <img
                src={member.img}
                alt={member.name}
                class="relative w-[200px] h-[200px] rounded-full object-cover object-top"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
            <!-- Bio content -->
            <div class="flex-1">
              <h2 style="font-family: 'Varela Round', sans-serif; font-size: 2rem; font-weight: 300; color: #4632DA; margin-bottom: 4px;">{member.name}</h2>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 400; color: #6b7280; margin-bottom: 1.25rem;">{member.role}</p>
              {member.bio.map(paragraph => (
                <p style="font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 300; line-height: 1.6; color: #353535; margin-bottom: 0.75rem;">{paragraph}</p>
              ))}
              <a href={`mailto:${member.email}`} class="hero-btn inline-flex items-center gap-2 px-7 py-3 mt-4" style="background-color: #4632DA; color: #ffffff; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 500; text-transform: capitalize; text-decoration: none; border-radius: 30px;">
                Email {member.name}
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
              </a>
            </div>
            <!-- Decorative circle on right (faint) -->
            <div class="hidden md:block absolute -right-8 top-1/2 -translate-y-1/2 w-[160px] h-[160px] rounded-full pointer-events-none" style="background: rgba(6,217,250,0.06);"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support Team Grid -->
  <section class="py-16 md:py-20" style="background: #f9f9f9;">
    <div class="max-w-[1100px] mx-auto px-4">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
        {supportTeam.map(person => (
          <div class="text-center">
            <img src={person.img} alt={person.name} class="w-[120px] h-[120px] mx-auto mb-3 rounded-full object-cover object-top" loading="lazy" />
            <h3 style="font-family: 'Varela Round', sans-serif; font-size: 1rem; font-weight: 400; color: #353535;">{person.name}</h3>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 400; color: #6b7280;">{person.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company Affiliation — infinite logo carousel -->
  <section class="py-16 md:py-20">
    <div class="max-w-[1100px] mx-auto px-4">
      <SectionHeading kicker="we work with them" title="Company Affiliation" subtitle="The following are just a few of the over 40 top insurance companies we access to compare their rates to find the best plan to fit your needs." />
      <div class="about-logo-slider overflow-hidden relative" style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
        <div class="about-logo-track flex items-center gap-16" id="about-logo-track">
          {partners.map(p => (
            <img src={p.url} alt={p.name} class="h-12 md:h-16 w-auto object-contain shrink-0" loading="lazy" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes about-logo-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .about-logo-track {
      animation: about-logo-scroll 30s linear infinite;
      width: max-content;
    }
    .about-logo-track:hover {
      animation-play-state: paused;
    }
  </style>

  <script>
    const aboutTrack = document.getElementById('about-logo-track');
    if (aboutTrack) {
      aboutTrack.innerHTML += aboutTrack.innerHTML;
    }
  </script>

  <!-- CTA — Get A Life Insurance Quote -->
  <section class="py-16 text-center" style="background: #f9f9f9;">
    <div class="max-w-3xl mx-auto px-4">
      <a href="/life-quote/" class="hero-btn inline-flex items-center gap-2 px-8 py-4" style="background-color: #4632DA; color: #ffffff; font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 500; text-transform: capitalize; text-decoration: none; border-radius: 30px;">
        Get A Life Insurance Quote
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
      </a>
    </div>
  </section>

</Layout>
