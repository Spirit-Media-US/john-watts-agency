---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Health Insurance Marketplace — Johnny Watts Agency" description="Navigate the Health Insurance Marketplace with a specialist. Johnny Watts Agency helps you find affordable health coverage.">

  <section class="bg-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-3">Health Insurance Marketplace</h1>
      <p class="text-gray-300 text-lg">Navigate your health coverage options with expert guidance</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 prose prose-lg">
      <!-- Health marketplace content will be migrated from existing site in Phase 3 -->
      <p class="text-gray">
        Health Insurance Marketplace content will be added during the content migration phase. This page will cover marketplace options, enrollment, and how our agents can help you find the right plan.
      </p>
    </div>
  </section>

  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Find Your Health Insurance Plan</h2>
      <a href="/health-insurance-marketplace-services-quote/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
        Get a Quote
      </a>
    </div>
  </section>

</Layout>
