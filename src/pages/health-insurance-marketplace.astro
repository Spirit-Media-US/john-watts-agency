---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Health Insurance Marketplace — Johnny Watts Agency" description="Navigate the Health Insurance Marketplace with a specialist. Johnny Watts Agency helps you find affordable health coverage.">

  <section class="bg-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-3">Health Insurance Marketplace</h1>
      <p class="text-gray-300 text-lg">Navigate your health coverage options with expert guidance</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Hero image placeholder — will be replaced with R2/Sanity image -->
      <div class="w-full h-64 bg-gray-200 rounded-lg mb-8"></div>

      <p class="text-lg text-gray leading-relaxed mb-6">
        Here at Johnny Watts Agency, you can be sure that we will give you the options that give you the most benefits. We will consider all of your needs and find the provider that best matches those.
      </p>
      <p class="text-lg text-gray leading-relaxed">
        Call us at <a href="tel:8286354200" class="text-primary font-semibold hover:text-primary-dark">(828) 635-4200</a> to speak with a specialist today.
      </p>
    </div>
  </section>

  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Find Your Health Insurance Plan</h2>
      <p class="text-blue-100 mb-6">Let us help you navigate the marketplace and find the right coverage.</p>
      <a href="/health-insurance-marketplace-services-quote/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
        Get a Quote
      </a>
    </div>
  </section>

</Layout>
