---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
---

<Layout title="Health Insurance Marketplace — Johnny Watts Agency" description="Navigate the Health Insurance Marketplace with a specialist. Johnny Watts Agency helps you find affordable health coverage.">

  <!-- Hero Banner -->
  <section class="relative text-white py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-dark"></div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white">Health Insurance Marketplace</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-gray leading-relaxed mb-8">
        Here at Johnny Watts Agency, you can be sure that we will give you the options that give you the most benefits. We will consider all of your needs and find the provider that best matches those.
      </p>
      <div class="text-center">
        <a href="/health-insurance-marketplace-services-quote/" class="btn">
          Get a Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="mb-2">Let's have a chat</h2>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
