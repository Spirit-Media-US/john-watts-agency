  { quote: "Working with Johnny was quick, painless and even saved me dollars.", name: "John G", location: "Creston, NC" },
  { quote: "Johnny and Donnie found my wife and me coverage we needed at good price.", name: "Barry & Jan H", location: "Ferguson, NC" },
  { quote: "Working with Johnny Watts replacing my coverage was the absolute best experience.", name: "Glenda K", location: "Greensboro, NC" },
  { quote: "Johnny Watts & agency helped me realize the importance of having life insurance.", name: "Bob S", location: "Atlanta, GA" },
  { quote: "I would highly recommend Johnny Watts Life Insurance Agency for life insurance.", name: "Jeannie C", location: "Highlands, NC" },
  { quote: "Johnny Watts was the only person to call me in person to discuss my needs.", name: "Russell W", location: "Hendersonville, NC" },
  { quote: "I was dropped by my current insurance co. Johnny Watts helped me find coverage.", name: "Gwen", location: "Parkton, NC" },
  { quote: "It was a pleasure doing business with you. I got the Life Insurance I need.", name: "Kathy B", location: "Marion, NC" },
  { quote: "Johnny was there for me with the best possible term life insurance rate.", name: "Michael K", location: "Walkertown, NC" },
  { quote: "I would like to thank Johnny Watts for helping me with my life insurance.", name: "Charlie S", location: "Anderson, SC" },
  { quote: "Johnny Watts provided exactly what I needed at the best affordable price.", name: "Mark B", location: "Rutherford College, NC" },
  { quote: "We were very pleased working with you and your office.", name: "Lee & Mike S", location: "Murphy, NC" },
  { quote: "Johnny and Donnie were great working with me and my schedule.", name: "Mike P", location: "Mooresville, NC" },
  { quote: "Johnny Watts was great to work with on our life insurance policy.", name: "Lisa & Michael W", location: "Yanceyville, NC" },
  { quote: "Johnny Watts and Donnie Bost were a pleasure to work with.", name: "Maureen L", location: "Raleigh, NC" },
  { quote: "Johnny was fantastic to work with. He helped me determine the best type.", name: "Jeff R", location: "Raleigh, NC" },
  { quote: "Johnny Watts Insurance Agency was very professional, knowledgeable and courteous.", name: "Deneice E", location: "Salisbury, NC" },
  { quote: "I was needing help making decisions about my life insurance.", name: "Susan J", location: "High Point, NC" },
  { quote: "Buying Life Insurance can be very confusing, Johnny Watts made me feel confident.", name: "Gary P", location: "Denver, NC" },
  { quote: "My wife and I would recommend Johnny Watts and Donnie Bost to anyone.", name: "Bob & Judy B", location: "Statesville, NC" },
  { quote: "Johnny Watts and Donnie Bost started out as agents, but quickly became friends.", name: "April T", location: "Taylorsville, NC" },
  { quote: "Johnny Watts Insurance made my shopping experience the best.", name: "Jason P", location: "Mooresville, NC" },
  { quote: "We didn't know who to go to for life insurance. Johnny was great.", name: "Timothy & Stacey V", location: "Denver, NC" },
  { quote: "Johnny, the world would be better if people conducted business as you do.", name: "Beda Wray", location: "Catawba, NC" },
  { quote: "Thanks for all your help in finding the right policy.", name: "Charlie & Jeong A", location: "Lexington, NC" },
  { quote: "I would just like to say Johnny has been very helpful.", name: "Gary G", location: "Winston Salem, NC" },
  { quote: "After talking with you, both put me at ease while we looked at options.", name: "Miss Sara H", location: "Asheville, NC" },
  { quote: "I had a very special need and Johnny Watts was working with us.", name: "Tommy T", location: "Marshville, NC" },
  { quote: "Johnny Watts was a great help in finding a policy I could afford.", name: "Roland H", location: "West Jefferson, NC" },
  { quote: "My wife and I recently engaged Johnny Watts and Donnie Bost for policies.", name: "Stefan S", location: "Black Mountain, NC" },
  { quote: "It was a pleasure doing business with Johnny and Donnie.", name: "Robert & Patricia S", location: "Silva, NC" },
  { quote: "Johnny Watts did his homework before finding life insurance for my wife and me.", name: "Neil H", location: "Lincolnton, NC" },
  { quote: "Johnny Watts did a wonderful job finding me the lowest rates possible.", name: "Vickie I", location: "Elon, NC" },
  { quote: "Johnny Watts and Donnie Bost helped me find a policy doubling my coverage.", name: "Len P", location: "Mooresville, NC" },
  { quote: "Johnny Watts is a pleasure to do business with and I recommend him.", name: "Dan A", location: "Hendersonville, NC" },
  { quote: "Johnny Watts earned my trust and confidence from the first phone call.", name: "Tommy M", location: "NC" },
  { quote: "My wife and I were really amazed at the customer service.", name: "Reggie & Tanya D", location: "Charlotte, NC" },
  { quote: "Johnny Watts has been a great guy. He has helped me plenty.", name: "Shaun S", location: "Gastonia, NC" },
  { quote: "Johnny Watts earned my trust from the first phone call.", name: "Tommy M", location: "Halifax, NC" },
  { quote: "Thanks for keeping check on us and the great policy.", name: "Ken & Anita E", location: "Spruce Pine, NC" },
  { quote: "Johnny Watts helped me pick out a life insurance policy.", name: "Gary G", location: "Forest City, NC" },
  { quote: "Johnny, you were very helpful in finding the cheapest life insurance.", name: "Debbie S", location: "Yadkinville, NC" },
  { quote: "Johnny Watts and Donnie Bost take the guess work out of buying insurance.", name: "Billy C", location: "Cherryville, NC" },
  { quote: "Johnny Watts and his office were helpful in finding life insurance.", name: "Wayne M", location: "Hayesville, NC" },
  { quote: "Johnny Watts found me the best life insurance for my needs.", name: "Connie S", location: "Statesville, NC" },
  { quote: "After the loss of my husband, Johnny Watts helped me get insurance.", name: "Christine N", location: "Bessimer City, NC" },
];
---

<Layout title="Johnny Watts Agency — Your Trusted Insurance Specialists">

  <!-- Hero -->
  <section class="relative text-white py-24 md:py-36 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://cdn.sanity.io/images/ssbenczy/production/0ea061d233b07bc91d306af7b3615e7d9bba7875-2560x1707.jpg?w=1920&q=80&auto=format"
        alt="Happy family"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-dark/60"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-4">We Are Your Trusted Specialists</h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-8" style="font-size:20px;">
        We are your Medicare, Health Insurance Marketplace, and Life Insurance specialists. Our decades of combined experience are at your service to ensure that you will get the best options for your needs.
      </p>
      <a href="/about/" class="inline-block px-8 py-3 bg-dark text-white rounded-full font-semibold hover:bg-white hover:text-dark transition-colors" style="font-size:1.125em;">
        about us
      </a>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="mb-6">Why Choose Johnny Watts Agency?</h2>
      <p class="text-gray leading-relaxed mb-8" style="font-size:20px;">
        We specialize in providing Medicare, Health Insurance, and Life Insurance services. We know that decisions concerning these are not to be taken lightly and that's why we take the time to understand your needs and we're here to guide you through the process with expertise and dedication. You might ask, "How are you different?" Good question. As a recruiter, I help Medicare and insurance agents all across America find the best companies to recommend to their clients. As your local agent, I'll access over 40 top insurance companies and compare their rates for the plan that fits you best. In addition, my platform is a top-tier health insurance marketplace that offers services tailored to your needs.
      </p>
      <a href="/about/" class="inline-block px-8 py-3 bg-dark text-white rounded-full font-semibold hover:bg-white hover:text-dark transition-colors" style="font-size:1.125em;">
        learn more
      </a>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Company Affiliation" subtitle="The following are just a few of the over 40 top insurance companies we access to compare their rates to find the best plan to fit your needs." />
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-6 items-center justify-items-center max-w-4xl mx-auto">
        {[
          { name: 'AGLA', url: 'https://cdn.sanity.io/images/ssbenczy/production/b8e0a789d04d62a2fd1e0538799c6831d4a1aac6-185x60.jpg' },
          { name: 'American National', url: 'https://cdn.sanity.io/images/ssbenczy/production/b3dffa7a7c32262a29ebf26383dcd8f65d4086c3-130x65.jpg' },
          { name: 'Fidelity', url: 'https://cdn.sanity.io/images/ssbenczy/production/dd090850bf552966e65cd52e952e605ef7eb9223-247x65.jpg' },
          { name: 'Foresters', url: 'https://cdn.sanity.io/images/ssbenczy/production/7686f230344bdd7f8974ea2c72f977c8471c40be-200x65.jpg' },
          { name: 'Genworth', url: 'https://cdn.sanity.io/images/ssbenczy/production/2103612e7019f0d2591ac7d1c69330476ea0b880-307x65.jpg' },
          { name: 'ING', url: 'https://cdn.sanity.io/images/ssbenczy/production/ca2dc24c25284beab614dd96bead93f99a7c7d59-153x35.jpg' },
          { name: 'Legal & General', url: 'https://cdn.sanity.io/images/ssbenczy/production/b5565c852b423b27bcc997bad72bfc2cd3afb163-98x82.jpg' },
          { name: 'Lincoln', url: 'https://cdn.sanity.io/images/ssbenczy/production/76c789e697e046e845e780bcb147487766655a3a-146x57.jpg' },
          { name: 'MetLife', url: 'https://cdn.sanity.io/images/ssbenczy/production/05d4d77751bc2f81b436a4d872f4aa3495c08638-144x46.jpg' },
          { name: 'Mutual of Omaha', url: 'https://cdn.sanity.io/images/ssbenczy/production/76fa126d3c4533cf3d911eb37ebad45984f920f9-270x56.jpg' },
          { name: 'North American', url: 'https://cdn.sanity.io/images/ssbenczy/production/b7e9e82ae195ef9af9e48d6ef3978fe09456ad06-193x109.jpg' },
          { name: 'Protective', url: 'https://cdn.sanity.io/images/ssbenczy/production/9f786a73c274d11f7734dbb5e96cd0e4eb2d4ef7-184x51.jpg' },
          { name: 'Prudential', url: 'https://cdn.sanity.io/images/ssbenczy/production/04f871ccac0d7f2a3bc7059bc6e3740ef751883f-231x68.jpg' },
          { name: 'Transamerica', url: 'https://cdn.sanity.io/images/ssbenczy/production/07112f2ba5d3602bd6e8ad2372208f757694e2d3-185x59.jpg' },
          { name: 'United Home Life', url: 'https://cdn.sanity.io/images/ssbenczy/production/fd35eec45f6b99e3039ee12f21b88cccd3219cd8-118x64.jpg' },
        ].map(p => (
          <img src={p.url} alt={p.name} class="h-12 md:h-16 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Team Preview -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading kicker="our work inspires smiles" title="The Faces Behind Our Success" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { name: 'Johnny Watts', img: 'https://cdn.sanity.io/images/ssbenczy/production/5ccfd6e5b2c4320f9e34e9e2c6f2ce32cb9dfb8a-500x500.png' },
          { name: 'Donnie Bost', img: 'https://cdn.sanity.io/images/ssbenczy/production/b1a5cca6b20ddfdffe94f7b4f11eac4e16a2b5c8-500x500.png' },
          { name: 'Linsey Stuckey', img: 'https://cdn.sanity.io/images/ssbenczy/production/00a64e66e6e20dbe2bde2b3e8d06370e9ed0e8d3-500x500.png' },
          { name: 'Tiffany Billey', img: 'https://cdn.sanity.io/images/ssbenczy/production/bd02becb1446c960bae66fde9f137ec9e501dfff-1499x1405.png' },
        ].map(member => (
          <div class="bg-gray-light rounded-lg p-6 text-center">
            <img src={`${member.img}?w=200&h=200&fit=crop&auto=format`} alt={member.name} class="w-32 h-32 mx-auto mb-4 rounded-full object-cover" loading="lazy" />
            <h4>{member.name}</h4>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/about/" class="px-8 py-3 bg-dark text-white rounded-full font-semibold hover:bg-white hover:text-dark transition-colors">
          About Us
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading kicker="we love them" title="Client Testimonials" />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="testimonials-grid">
        {testimonials.slice(0, 6).map(t => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <p class="text-gray italic mb-4">"{t.quote}"</p>
            <p class="font-semibold text-dark">— {t.name}, {t.location}</p>
          </div>
        ))}
      </div>

      <!-- Hidden testimonials revealed by button -->
      <div id="more-testimonials" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
        {testimonials.slice(6).map(t => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <p class="text-gray italic mb-4">"{t.quote}"</p>
            <p class="font-semibold text-dark">— {t.name}, {t.location}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <button
          id="show-more-btn"
          class="px-8 py-3 bg-dark text-white rounded-full font-semibold hover:bg-white hover:text-dark transition-colors"
        >
          Show All {testimonials.length} Testimonials
        </button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="mb-6">Get a Quote</h2>
      <a href="/life-quote/" class="inline-block px-8 py-3 bg-dark text-white font-semibold rounded-full hover:bg-white hover:text-dark border border-dark transition-colors" style="font-size:1.125em;">
        Life Quote
      </a>
    </div>
  </section>

</Layout>

<script>
  const btn = document.getElementById('show-more-btn');
  const more = document.getElementById('more-testimonials');
  btn?.addEventListener('click', () => {
    more?.classList.toggle('hidden');
    if (more?.classList.contains('hidden')) {
      btn.textContent = `Show All Testimonials`;
    } else {
      btn.textContent = 'Show Fewer';
    }
  });
</script>
