---

<Layout title="Johnny Watts Agency — Your Trusted Insurance Specialists">

  <!-- Hero -->
  <section class="bg-dark text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-4">We Are Your Trusted Specialists</h1>
      <p class="text-lg text-gray-300 max-w-3xl mx-auto mb-8">
        We are your Medicare, Health Insurance Marketplace, and Life Insurance specialists. Our decades of combined experience are at your service to ensure that you will get the best options for your needs.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/about/" class="px-6 py-3 bg-primary text-white rounded-md font-semibold hover:bg-primary-dark transition-colors">
          About Us
        </a>
        <a href="/contact-us/" class="px-6 py-3 border-2 border-white text-white rounded-md font-semibold hover:bg-white hover:text-dark transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Your Health, Your Future, Your Family, Your Peace Of Mind" />
      <div class="max-w-3xl mx-auto text-center mb-10">
        <p class="text-gray leading-relaxed">
          We specialize in providing Medicare, Health Insurance, and Life Insurance services. We know that decisions concerning these are not to be taken lightly and that's why we take the time to understand your needs and we're here to guide you through the process with expertise and dedication. You might ask, "How are you different?" Good question. As a recruiter, I help Medicare and insurance agents all across America find the best companies to recommend to their clients. As your local agent, I'll access over 40 top insurance companies and compare their rates for the plan that fits you best. In addition, my platform is a top-tier health insurance marketplace that offers services tailored to your needs.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary/10 rounded-full flex items-center justify-center">
            <span class="text-3xl">🛡️</span>
          </div>
          <h3 class="mb-2">Medicare</h3>
          <p class="text-gray">Expert guidance through Medicare options to find the right coverage for your needs.</p>
          <a href="/medicare/" class="inline-block mt-4 text-primary font-semibold hover:text-primary-dark">Learn More →</a>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary/10 rounded-full flex items-center justify-center">
            <span class="text-3xl">🏥</span>
          </div>
          <h3 class="mb-2">Health Insurance</h3>
          <p class="text-gray">Navigate the Health Insurance Marketplace with a specialist who knows the options.</p>
          <a href="/health-insurance-marketplace/" class="inline-block mt-4 text-primary font-semibold hover:text-primary-dark">Learn More →</a>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary/10 rounded-full flex items-center justify-center">
            <span class="text-3xl">❤️</span>
          </div>
          <h3 class="mb-2">Life Insurance</h3>
          <p class="text-gray">Protect what matters most with the right life insurance policy for your family.</p>
          <a href="/learn-about-life-insurance/" class="inline-block mt-4 text-primary font-semibold hover:text-primary-dark">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Company Affiliations" subtitle="We work with over 40 top insurance companies to compare rates and find the plan that fits you best." />
      <!-- Partner logos will be added from R2 in Phase 3 -->
      <div class="text-center text-gray text-sm italic">
        Partner logos coming soon — Fidelity, Foresters, MetLife, Prudential, Lincoln, Transamerica, Protective, ING, Genworth, and more.
      </div>
    </div>
  </section>

  <!-- Team Preview -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="The Faces Behind Our Success" subtitle="Meet the team that's been serving your community for over 40 years." />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { name: 'Johnny Watts', role: 'Owner / Agent' },
          { name: 'Donnie Bost', role: 'Agent' },
          { name: 'Linsey Stuckey', role: 'Agent' },
          { name: 'Tiffany Billey', role: 'Agent' },
        ].map(member => (
          <div class="bg-gray-light rounded-lg p-6 text-center">
            <div class="w-24 h-24 mx-auto mb-4 bg-gray-300 rounded-full"></div>
            <h4>{member.name}</h4>
            <p class="text-sm text-gray">{member.role}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/about/" class="px-6 py-3 bg-primary text-white rounded-md font-semibold hover:bg-primary-dark transition-colors">
          About Us
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="What Our Clients Say" subtitle="Hear from families across North Carolina, South Carolina, and Georgia who trust Johnny Watts Agency." />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="testimonials-grid">
        {testimonials.slice(0, 6).map(t => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <p class="text-gray italic mb-4">"{t.quote}"</p>
            <p class="font-semibold text-dark">— {t.name}, {t.location}</p>
          </div>
        ))}
      </div>

      <!-- Hidden testimonials revealed by button -->
      <div id="more-testimonials" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
        {testimonials.slice(6).map(t => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <p class="text-gray italic mb-4">"{t.quote}"</p>
            <p class="font-semibold text-dark">— {t.name}, {t.location}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <button
          id="show-more-btn"
          class="px-6 py-3 bg-white text-primary border-2 border-primary rounded-md font-semibold hover:bg-primary hover:text-white transition-colors"
        >
          Show All {testimonials.length} Testimonials
        </button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Ready to Get Started?</h2>
      <p class="text-lg text-blue-100 mb-8">Get a free quote today — no obligation, just honest advice from agents who care.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/life-quote/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
          Life Quote
        </a>
        <a href="/medicare-quote/" class="inline-block px-8 py-3 border-2 border-white text-white font-semibold rounded-md hover:bg-white hover:text-primary transition-colors">
          Medicare Quote
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const btn = document.getElementById('show-more-btn');
  const more = document.getElementById('more-testimonials');
  btn?.addEventListener('click', () => {
    more?.classList.toggle('hidden');
    if (more?.classList.contains('hidden')) {
      btn.textContent = `Show All Testimonials`;
    } else {
      btn.textContent = 'Show Fewer';
    }
  });
</script>
