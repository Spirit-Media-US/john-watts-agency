            { name: 'Johnny Watts', img: 'https://cdn.sanity.io/images/ssbenczy/production/5369409619f9e4198af805133bb83d135e76bb70-500x500.png' },
            { name: 'Donnie Bost', img: 'https://cdn.sanity.io/images/ssbenczy/production/fb78382b2630258d0b53b830d71fba5bd0b27c6c-500x500.png' },
            { name: 'Linsey Stuckey', img: 'https://cdn.sanity.io/images/ssbenczy/production/d9e06beb0aaaa3b0232eae49ba9e424e66fd14f2-500x500.png' },
            { name: 'Tiffany Billey', img: 'https://cdn.sanity.io/images/ssbenczy/production/bd02becb1446c960bae66fde9f137ec9e501dfff-1499x1405.png' },
          ].map(m => (
            <div class="text-center">
              <div class="rounded-t-full rounded-b-3xl overflow-hidden mb-2">
                <img src={`${m.img}?w=250&h=300&fit=crop&auto=format`} alt={m.name} class="w-full object-cover aspect-[5/6]" loading="lazy" />
              </div>
              <p class="text-sm font-semibold">{m.name}</p>
            </div>
          ))}
        </div>
        <!-- Text -->
        <div>
          <p class="kicker">Our Work Inspires Smiles</p>
          <h2 class="mb-6" style="font-size:2.5rem; line-height:1.15;">The Faces Behind Our Success</h2>
          <a href="/about/" class="btn">About Us</a>
        </div>
      </div>
    </div>
    <!-- Decorative curve -->
    <div class="absolute -bottom-16 -left-16 w-72 h-72 border-4 border-primary/10 rounded-full hidden lg:block"></div>
  </section>

  <!-- ═══ TESTIMONIALS — heading LEFT, carousel RIGHT, two-column ═══ -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <!-- Left heading -->
        <div>
          <p class="kicker">We Love Them</p>
          <h2 style="font-size:2.5rem; line-height:1.15;">Client Testimonials</h2>
        </div>
        <!-- Right carousel -->
        <div>
          <div class="testimonial-carousel" id="testimonial-carousel">
            <div class="testimonial-track" id="testimonial-track">
              {testimonials.map((t, i) => (
                <div class="testimonial-slide" data-index={i}>
                  <p class="text-gray leading-relaxed mb-4" style="font-size:1rem;">"{t.quote}"</p>
                  <p class="font-bold text-dark">{t.name}</p>
                  <p class="text-sm text-gray">{t.location}</p>
                </div>
              ))}
            </div>
            <div class="testimonial-dots" id="testimonial-dots"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GET A QUOTE — dark gradient, left-aligned ═══ -->
  <section class="relative py-16 md:py-24 text-white" style="background: linear-gradient(135deg, #1a1a3e 0%, #2d1b69 50%, #0f0f2e 100%);">
    <!-- Wave top -->
    <div class="absolute top-0 left-0 w-full overflow-hidden leading-none" style="transform:rotate(180deg);">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-16 md:h-24">
        <path d="M0,80 C360,120 720,40 1440,80 L1440,120 L0,120 Z" fill="#ffffff"/>
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-4 pt-8">
      <h2 class="text-white mb-6" style="font-size:2.5rem;">Get A Quote</h2>
      <a href="/life-quote/" class="btn-outline inline-flex items-center gap-2 px-6 py-3 border-2 border-white text-white rounded-full font-semibold hover:bg-white hover:text-primary transition-colors" style="font-size:0.9375rem;">
        Life Quote <span>→</span>
      </a>
    </div>
  </section>

</Layout>

<script>
  // Testimonial carousel
  const track = document.getElementById('testimonial-track');
  const dotsContainer = document.getElementById('testimonial-dots');
  if (track && dotsContainer) {
    const slides = track.querySelectorAll('.testimonial-slide');
    const total = slides.length;
    let current = 0;
    let autoplayTimer: ReturnType<typeof setInterval>;

    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = 'testimonial-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Testimonial ${i + 1}`);
      dot.addEventListener('click', () => goTo(i));
      dotsContainer.appendChild(dot);
    }

    function goTo(index: number) {
      current = index;
      track.style.transform = `translateX(-${current * 100}%)`;
      dotsContainer.querySelectorAll('.testimonial-dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
      });
    }

    function next() {
      goTo((current + 1) % total);
    }

    autoplayTimer = setInterval(next, 5000);
    track.parentElement?.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
    track.parentElement?.addEventListener('mouseleave', () => {
      autoplayTimer = setInterval(next, 5000);
    });
  }
</script>
