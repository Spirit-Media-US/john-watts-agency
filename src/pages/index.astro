<script>
  // Testimonial carousel with windowed dot navigation
  const track = document.getElementById('testimonial-track');
  const dotsContainer = document.getElementById('testimonial-dots');
  if (track && dotsContainer) {
    const slides = track.querySelectorAll('.testimonial-slide');
    const total = slides.length;
    let current = 0;
    let autoplayTimer: ReturnType<typeof setInterval>;
    const maxVisibleDots = 7;

    function renderDots() {
      dotsContainer.innerHTML = '';
      // Show a window of dots around current position
      let start = Math.max(0, current - Math.floor(maxVisibleDots / 2));
      let end = Math.min(total, start + maxVisibleDots);
      if (end - start < maxVisibleDots) start = Math.max(0, end - maxVisibleDots);

      for (let i = start; i < end; i++) {
        const dot = document.createElement('button');
        dot.className = 'testimonial-dot' + (i === current ? ' active' : '');
        dot.setAttribute('aria-label', `Testimonial ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function goTo(index: number) {
      current = index;
      track.style.transform = `translateX(-${current * 100}%)`;
      renderDots();
    }

    function next() {
      goTo((current + 1) % total);
    }

    renderDots();
    autoplayTimer = setInterval(next, 5000);
    track.parentElement?.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
    track.parentElement?.addEventListener('mouseleave', () => {
      autoplayTimer = setInterval(next, 5000);
    });
  }
</script>
