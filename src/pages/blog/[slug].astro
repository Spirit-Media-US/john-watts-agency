---
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post"]{ "slug": slug.current }`);
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const post = await sanityClient.fetch(`*[_type == "post" && slug.current == $slug][0]{
  _id, title, excerpt, publishDate, author, tags, heroImage,
  "slug": slug.current,
  body, seoTitle, seoDescription
}`, { slug });

if (!post) return Astro.redirect('/404');

const allPosts = await sanityClient.fetch(`*[_type == "post"] | order(publishDate desc) {
  _id, title, excerpt, publishDate, "slug": slug.current, heroImage
}`);

// Fetch CTA image from siteSettings
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{ ctaImage }`);
const ctaImgUrl = settings?.ctaImage ? urlFor(settings.ctaImage).width(480).auto('format').url() : '/cta-post.png';

const currentIndex = allPosts.findIndex((p: any) => p.slug === slug);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const relatedPosts = allPosts.filter((_: any, i: number) => i !== currentIndex).slice(0, 2);

const date = new Date(post.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const heroUrl = post.heroImage ? urlFor(post.heroImage).width(800).auto('format').url() : '';

// Render Portable Text body to HTML
function renderBody(blocks: any[]): string {
  if (!blocks) return '';
  return blocks.map((block: any) => {
    if (block._type === 'block') {
      const text = (block.children || []).map((child: any) => {
        let t = child.text || '';
        if (child.marks?.includes('strong')) t = `<strong>${t}</strong>`;
        if (child.marks?.includes('em')) t = `<em>${t}</em>`;
        // Handle link marks
        for (const mark of child.marks || []) {
          const markDef = (block.markDefs || []).find((m: any) => m._key === mark);
          if (markDef?.href) t = `<a href="${markDef.href}">${t}</a>`;
        }
        return t;
      }).join('');

      switch (block.style) {
        case 'h2': return `<h2>${text}</h2>`;
        case 'h3': return `<h3>${text}</h3>`;
        case 'blockquote': return `<blockquote>${text}</blockquote>`;
        default: return `<p>${text}</p>`;
      }
    }
    if (block._type === 'image' && block.asset) {
      const src = urlFor(block).width(700).auto('format').url();
      return `<img src="${src}" alt="${block.alt || 'Blog post image'}" width="700" height="400" loading="lazy" decoding="async" class="rounded-lg" />`;
    }
    return '';
  }).join('\n');
}

const bodyHtml = renderBody(post.body);
const author = post.author || 'Johnny Watts Agency';
const tags = post.tags || [];
const canonicalUrl = `https://johnnywattsagency.com/blog/${post.slug}/`;
---

<Layout
  title={post.seoTitle || `${post.title} | Johnny Watts Agency Blog`}
  description={post.seoDescription || post.excerpt || `Read ${post.title} on the Johnny Watts Agency blog.`}
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt || post.title,
      "image": heroUrl,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Organization", "name": "Johnny Watts Agency", "url": "https://johnnywattsagency.com" },
      "url": canonicalUrl,
      "datePublished": post.publishDate
    })}></script>
  </Fragment>
  <article>
    <!-- Hero -->
    <header class="relative overflow-hidden text-white text-center pt-[120px] pb-[160px] bg-gradient-hero">
      <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1440 500" xmlns="http://www.w3.org/2000/svg">
        <path d="M-50,-50 C100,-30 250,80 280,200 C310,320 200,420 80,440 C-40,460 -120,380 -150,250 C-180,120 -100,-70 -50,-50 Z" fill="rgba(255,255,255,0.07)" />
        <path d="M1200,-50 C1350,0 1480,120 1500,280 C1520,440 1450,550 1320,520 C1190,490 1100,350 1100,200 C1100,50 1150,-50 1200,-50 Z" fill="rgba(255,255,255,0.08)" />
      </svg>
      <div class="relative max-w-3xl mx-auto px-4 z-[2]">
        <h1 class="mb-4 font-heading text-[clamp(24px,5vw,40px)] font-light leading-[1.2] capitalize text-white">{post.title}</h1>
        <p class="text-sm font-normal text-white/80">
          <span>{post.author || 'kevin'}</span>
          <span class="mx-2">·</span>
          <span>{date}</span>
        </p>
      </div>
      <div class="absolute bottom-[-1px] left-0 w-full overflow-hidden leading-none z-[3] dir-ltr">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" class="wave-svg">
          <path d="M0,40 C167,80 333,0 500,40 C667,80 833,0 1000,40 L1000,0 L0,0 Z" fill="#ffffff"/>
        </svg>
      </div>
    </header>

    <!-- Featured Image -->
    {heroUrl && (
      <div class="relative max-w-3xl mx-auto px-4 z-[4] mt-clamp-overlap">
        <img src={heroUrl} alt={post.title} class="w-full rounded-lg shadow-lg aspect-video object-cover" width="768" height="432" decoding="async" />
      </div>
    )}

    <!-- Tags -->
    {tags.length > 0 && (
      <section class="max-w-3xl mx-auto px-4 pt-6 pb-2">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <a href={`/blogs/?tag=${encodeURIComponent(tag)}`} class="text-xs font-semibold text-gray bg-gray-light hover:bg-primary hover:text-white rounded-full px-3 py-1 transition-colors no-underline">
              {tag}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Share Bar -->
    <div class="max-w-3xl mx-auto px-4 py-6">
      <div class="flex items-center justify-between border-b border-gray-200 pb-4">
        <p class="font-heading text-base font-light text-dark">Share This Post</p>
        <div class="flex items-center gap-4">
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${Astro.url}`} target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full flex items-center justify-center transition-colors bg-gray-light text-gray" aria-label="Share on Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/></svg>
          </a>
          <button class="share-copy w-11 h-11 rounded-full flex items-center justify-center transition-colors bg-gray-light text-gray border-none cursor-pointer" aria-label="Copy link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </button>
          <a href={`https://twitter.com/intent/tweet?url=${Astro.url}&text=${encodeURIComponent(post.title)}`} target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full flex items-center justify-center transition-colors bg-gray-light text-gray" aria-label="Share on Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.44 4.83c-.8.37-1.5.38-2.22.02.93-.56.98-.96 1.32-2.02-.88.52-1.86.9-2.9 1.1-.82-.88-2-1.43-3.3-1.43-2.5 0-4.55 2.04-4.55 4.54 0 .36.03.7.1 1.04-3.77-.2-7.12-2-9.36-4.75-.4.67-.6 1.45-.6 2.3 0 1.56.8 2.95 2 3.77-.74-.03-1.44-.23-2.05-.57v.06c0 2.2 1.56 4.03 3.64 4.44-.67.18-1.37.2-2.06.08.58 1.8 2.26 3.12 4.25 3.16C5.78 18.1 3.37 18.74 1 18.46c2 1.3 4.4 2.04 6.97 2.04 8.35 0 12.92-6.92 12.92-12.93 0-.2 0-.4-.02-.6.9-.63 1.96-1.22 2.56-2.14z"/></svg>
          </a>
          <a href={`mailto:?subject=${encodeURIComponent(post.title)}&body=${Astro.url}`} class="w-11 h-11 rounded-full flex items-center justify-center transition-colors bg-gray-light text-gray" aria-label="Share via Email">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Blog Content from Sanity -->
    <div class="pb-12">
      <div class="max-w-3xl mx-auto px-4 prose-content" set:html={bodyHtml} />
    </div>

    <!-- Newsletter -->
    <div class="max-w-2xl mx-auto px-4 mb-16">
      <div class="rounded-xl shadow-lg overflow-hidden border-gradient-bottom">
        <div class="p-5 md:p-8 text-center">
          <h3 class="mb-2 font-heading text-[24px] font-light text-secondary">Subscribe To Our Newsletter</h3>
          <p class="mb-6 text-sm font-light text-gray">Get updates and learn from the best</p>
          <form class="flex gap-3 max-w-md mx-auto">
            <input type="email" placeholder="Enter Your Email" class="flex-1 px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
            <button type="submit" class="hero-btn inline-flex items-center gap-2 px-6 py-3 bg-accent text-white text-sm font-medium border-none rounded-[30px] cursor-pointer whitespace-nowrap">
              Send
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 44 448 424"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Prev / Next -->
    <div class="max-w-3xl mx-auto px-4 mb-16">
      <div class="flex justify-between items-start border-t border-gray-200 pt-6">
        {prevPost ? (
          <a href={`/blog/${prevPost.slug}/`} class="group max-w-[45%] no-underline">
            <span class="text-sm font-semibold text-primary">Previous</span>
            <p class="mt-1 group-hover:text-primary transition-colors text-[13px] font-normal text-gray leading-[1.4]">{prevPost.title}</p>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.slug}/`} class="group max-w-[45%] text-right ml-auto no-underline">
            <span class="text-sm font-semibold text-primary">Next</span>
            <p class="mt-1 group-hover:text-primary transition-colors text-[13px] font-normal text-gray leading-[1.4]">{nextPost.title}</p>
          </a>
        ) : <div />}
      </div>
    </div>

    <!-- Share Bar (protocol component) -->
    <ShareBar title={post.title} url={canonicalUrl} />

    <!-- Related Posts (protocol component — scores by shared tags) -->
    <RelatedPosts currentSlug={`/blog/${post.slug}`} currentTags={tags} />
  </article>

  <!-- CTA -->
  <div class="relative m-0 p-0">
    <div class="relative overflow-hidden pt-[120px] pb-[60px] overflow-x-clip overflow-y-visible bg-gradient-cta">
      <div class="absolute left-0 w-full overflow-hidden leading-none top-[-1px] z-[2]">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100" preserveAspectRatio="none" class="wave-svg-narrow-flat">
          <path d="M0,100 C480,100 960,0 1440,0 L1440,0 L0,0 Z" fill="#ffffff"/>
        </svg>
      </div>
      <svg class="absolute pointer-events-none left-[-60px] top-0 w-[200px] h-full opacity-45" viewBox="0 0 200 400" xmlns="http://www.w3.org/2000/svg">
        <path d="M80,-30 C170,10 220,130 190,250 C160,370 60,380 0,300 C-60,220 -50,80 10,10 C40,-20 50,-40 80,-30 Z" fill="rgba(70,50,218,0.6)" />
      </svg>
      <div class="relative max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row items-center gap-8 z-[2]">
        <div class="md:w-[45%] text-white">
          <h2 class="mb-3 font-heading text-[clamp(24px,4vw,36px)] font-light text-white leading-[1.2]">Do You Want To Boost Your Business?</h2>
          <p class="mb-6 text-[15px] font-light text-white/85">Drop Us A Line And Keep In Touch</p>
          <a href="/contact-us/" class="inline-flex items-center gap-2 px-7 py-3 transition-all hover:shadow-lg bg-white text-accent text-[15px] font-medium no-underline rounded-[30px]">
            Contact Us
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 44 448 424"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
          </a>
        </div>
        <div class="md:w-[55%] flex justify-center md:justify-end mt-clamp-overlap-sm">
          <img src={ctaImgUrl} alt="Business team meeting" class="w-full max-w-[480px] block blob-shape-1 shadow-[0_10px_30px_rgba(0,0,0,0.15)]" loading="lazy" />
        </div>
      </div>
    </div>
  </div>

  <script>
    document.querySelector('.share-copy')?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href);
      const btn = document.querySelector('.share-copy') as HTMLElement | null;
      if (btn) {
        btn.style.background = '#4632DA';
        btn.style.color = '#fff';
        setTimeout(() => { btn.style.background = '#f3f4f6'; btn.style.color = '#4b5563'; }, 1500);
      }
    });
  </script>
</Layout>

<style>
  .prose-content :global(h2) { font-family: 'Varela Round', sans-serif; font-size: 1.5rem; font-weight: 300; color: #3D4459; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose-content :global(h3) { font-family: 'Varela Round', sans-serif; font-size: 1.25rem; font-weight: 300; color: #3D4459; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose-content :global(p) { font-family: 'Montserrat', sans-serif; color: #353535; font-weight: 300; line-height: 1.8; margin-bottom: 1rem; }
  .prose-content :global(ul), .prose-content :global(ol) { color: #353535; padding-left: 1.5rem; margin-bottom: 1rem; line-height: 1.8; }
  .prose-content :global(li) { margin-bottom: 0.5rem; font-weight: 300; }
  .prose-content :global(strong) { color: #353535; font-weight: 600; }
  .prose-content :global(a) { color: #4632DA; text-decoration: underline; }
  .prose-content :global(a:hover) { color: #3526b0; }
  .prose-content :global(img) { width: 100%; border-radius: 8px; margin: 1.5rem 0; }
</style>
