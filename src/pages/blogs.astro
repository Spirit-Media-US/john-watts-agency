---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const posts = [
  {
    title: 'The Ultimate Guide to Choosing the Right Life Insurance Policy',
    slug: '/blog/the-ultimate-guide-to-choosing-the-right-life-insurance-policy/',
    date: 'September 25, 2024',
    excerpt: 'Learn how to choose the right life insurance policy. Tips on assessing needs, comparing quotes, and avoiding common mistakes.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/09/The-Ultimate-Guide-to-Choosing-the-Right-Life-Insurance-Policy-2-1024x683.jpg',
  },
  {
    title: 'The Importance of Life Insurance for Young Families',
    slug: '/blog/the-importance-of-life-insurance-for-young-families/',
    date: 'September 25, 2024',
    excerpt: 'Why life insurance is essential for young families. Tips on choosing the right policy and avoiding common mistakes.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/09/The-Importance-of-Life-Insurance-for-Young-Families-2-1024x683.jpg',
  },
  {
    title: 'Medicare and Long-Term Care: Planning for Future Healthcare Needs',
    slug: '/blog/medicare-and-long-term-care-planning/',
    date: 'September 25, 2024',
    excerpt: 'Plan for future healthcare needs by understanding Medicare and long-term care options.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/09/Medicare-and-Long-Term-Care-Planning-for-Future-Healthcare-Needs-2-1024x683.jpg',
  },
  {
    title: "Choosing the Right Plan: A Health Insurance Specialist's Guide",
    slug: '/blog/choosing-the-right-health-insurance-plan/',
    date: 'September 25, 2024',
    excerpt: "A health insurance specialist's guide to choosing the right plan. Assess needs, compare costs, avoid mistakes.",
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/09/Choosing-the-Right-Plan-A-Health-Insurance-Specialist_s-Guide-to-Navigating-Options-1-1024x683.jpg',
  },
  {
    title: 'Understanding the Role of a Life Insurance Specialist: Five Things You Need to Know',
    slug: '/blog/understanding-the-role-of-a-life-insurance-specialist/',
    date: 'April 24, 2024',
    excerpt: 'Learn what a life insurance specialist does and how they help you find the right coverage.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/04/watts-claim-assistance-1.jpg',
  },
  {
    title: '7 Ways to a Secure and Healthy Retirement',
    slug: '/blog/7-ways-to-a-secure-and-healthy-retirement/',
    date: 'April 8, 2024',
    excerpt: 'Seven practical strategies for a secure retirement, from saving early to understanding Medicare and life insurance.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/04/Johnny-Watts-1.jpg',
  },
  {
    title: 'Six Reasons Why You Need To Review Your Life Insurance Annually',
    slug: '/blog/six-reasons-to-review-life-insurance-annually/',
    date: 'February 19, 2024',
    excerpt: 'Why an annual life insurance review is essential. Six key reasons to keep your coverage aligned with your needs.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/02/Image-1-2.jpg',
  },
  {
    title: 'Five Overlooked Truths About Health Insurance',
    slug: '/blog/five-overlooked-truths-about-health-insurance/',
    date: 'February 8, 2024',
    excerpt: 'Five essential truths about health insurance that are often overlooked.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/02/Image-1-1.jpg',
  },
  {
    title: 'Protecting What Matters: Understanding Life Insurance',
    slug: '/blog/protecting-what-matters-understanding-life-insurance/',
    date: 'January 11, 2024',
    excerpt: 'Understand the basics of life insurance, its benefits, coverage needs, and common misconceptions.',
    img: 'https://johnnywattsagency.com/wp-content/uploads/2024/01/Image-1-1-1024x576.png',
  },
];
---

<Layout title="Blog — Johnny Watts Agency" description="Insurance tips, guides, and news from Johnny Watts Agency. Learn about Medicare, health insurance, and life insurance.">

  <PageHero title="Blogs" />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
        {posts.map((post, i) => (
          <article class:list={['blog-card bg-gray-light rounded-lg overflow-hidden hover:shadow-md transition-shadow', { hidden: i >= 6 }]}>
            <img src={post.img} alt={post.title} class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-5">
              <p class="text-xs text-gray mb-2">{post.date}</p>
              <h3 class="text-lg mb-2">
                <a href={post.slug} style="color: #353535; text-decoration: none;" class="hover:text-primary transition-colors">
                  {post.title}
                </a>
              </h3>
              <p class="text-sm text-gray mb-3">{post.excerpt}</p>
              <a href={post.slug} class="text-sm font-semibold" style="color: #4632DA;">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
      <!-- Pagination -->
      <div class="flex justify-center items-center gap-3 mt-12" id="blog-pagination">
        <button id="prev-page" class="px-4 py-2 rounded-md text-sm font-medium" style="background: #f3f4f6; color: #6b7280; cursor: pointer; border: none;" disabled>
          ← Previous
        </button>
        <span id="page-info" style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #6b7280;">Page 1 of {Math.ceil(posts.length / 6)}</span>
        <button id="next-page" class="px-4 py-2 rounded-md text-sm font-medium" style="background: #4632DA; color: #ffffff; cursor: pointer; border: none;">
          Next →
        </button>
      </div>
    </div>
  </section>

  <script>
    const perPage = 6;
    const cards = document.querySelectorAll('.blog-card');
    const totalPages = Math.ceil(cards.length / perPage);
    let currentPage = 1;

    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info')!;

    function showPage(page: number) {
      currentPage = page;
      const start = (page - 1) * perPage;
      const end = start + perPage;
      cards.forEach((card, i) => {
        card.classList.toggle('hidden', i < start || i >= end);
      });
      pageInfo.textContent = `Page ${page} of ${totalPages}`;
      prevBtn.disabled = page === 1;
      prevBtn.style.background = page === 1 ? '#f3f4f6' : '#4632DA';
      prevBtn.style.color = page === 1 ? '#6b7280' : '#ffffff';
      nextBtn.disabled = page === totalPages;
      nextBtn.style.background = page === totalPages ? '#f3f4f6' : '#4632DA';
      nextBtn.style.color = page === totalPages ? '#6b7280' : '#ffffff';
      window.scrollTo({ top: document.getElementById('blog-grid')!.offsetTop - 120, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1); });
    nextBtn.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1); });
  </script>

</Layout>
