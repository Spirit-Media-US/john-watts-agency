---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { sanityClient, urlFor } from '../lib/sanity';

const rawSanityPosts = await sanityClient.fetch(`
  *[_type == "post"] | order(publishDate desc) {
    "slug": "/blog/" + slug.current + "/",
    title,
    excerpt,
    "image": coalesce(heroImage.asset->url + "?w=800&auto=format", ""),
    "imagePosition": "center center",
    "author": coalesce(author, "Johnny Watts Agency"),
    "date": publishDate,
    tags
  }
`);

const MONTHS = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
const sanityPostsFormatted = rawSanityPosts.map((p: any) => {
  const d = new Date(p.date);
  return { ...p, date: `${MONTHS[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}` };
});
const SANITY_POSTS_JSON = JSON.stringify(sanityPostsFormatted);
---

<Layout
  title="Insurance Blog — Medicare, Health & Life Insurance Tips | Johnny Watts Agency"
  description="Expert insurance tips, Medicare enrollment guides, and life insurance advice from Johnny Watts Agency. Stay informed about your coverage options in North Carolina."
>
  <Fragment slot="head">
    <meta name="keywords" content="medicare tips, health insurance guide, life insurance advice, insurance blog, Johnny Watts Agency, North Carolina insurance" />
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Johnny Watts Agency Blog",
      "url": "https://johnnywattsagency.com/blogs",
      "description": "Expert insurance tips, Medicare enrollment guides, and life insurance advice from Johnny Watts Agency.",
      "publisher": { "@type": "Organization", "name": "Johnny Watts Agency", "url": "https://johnnywattsagency.com" }
    })}></script>
  </Fragment>
  <main id="main-content">

    <!-- HERO -->
    <section class="bg-gray-light px-6 py-12 lg:py-20 lg:px-8 overflow-hidden">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="kicker mb-4 text-accent">Blog</p>
            <h1 class="font-heading font-light text-secondary text-clamp-hero-sm">Insurance Insights<br />& Expert Tips</h1>
            <p class="mt-6 body-text-lg max-w-xl">Medicare enrollment guides, health insurance tips, and life insurance advice from Taylorsville's most trusted insurance team.</p>
          </div>
          <div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true">
            {rawSanityPosts.slice(0, 9).map((post: any, i: number) => (
              <div class="relative rounded-2xl overflow-hidden aspect-square">
                {post.image && <img src={post.image} alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" width="200" height="200" />}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- SEARCH + FILTER (sticky) -->
    <section class="bg-white border-b border-gray-200 px-6 py-4 lg:px-8 sticky top-0 z-10 shadow-sm">
      <div class="mx-auto max-w-7xl flex flex-col gap-3">
        <div class="flex items-center gap-3">
          <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
            <input
              id="blog-search"
              type="search"
              placeholder="Search by keyword, topic, or tag..."
              class="w-full pl-9 pr-4 py-2 rounded-lg border border-gray-300 bg-gray-light text-sm text-dark focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent min-h-[44px]"
            />
          </div>
          <p id="results-count" class="text-sm text-gray whitespace-nowrap shrink-0"></p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs font-semibold text-gray uppercase tracking-wider shrink-0">Filter:</span>
          <button data-tag="all" class="tag-chip active px-3 py-1 rounded-full text-xs font-semibold border transition-colors bg-primary text-white border-primary min-h-[44px]">All</button>
          <button data-tag="medicare" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray hover:border-primary hover:text-primary transition-colors min-h-[44px]">Medicare</button>
          <button data-tag="health-insurance" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray hover:border-primary hover:text-primary transition-colors min-h-[44px]">Health Insurance</button>
          <button data-tag="life-insurance" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray hover:border-primary hover:text-primary transition-colors min-h-[44px]">Life Insurance</button>
          <button data-tag="retirement" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray hover:border-primary hover:text-primary transition-colors min-h-[44px]">Retirement</button>
          <button data-tag="financial-planning" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray hover:border-primary hover:text-primary transition-colors min-h-[44px]">Financial Planning</button>
        </div>
      </div>
    </section>

    <!-- POSTS GRID -->
    <section class="bg-gray-light py-12 lg:py-20 px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>

        <div id="no-results" class="hidden text-center py-20">
          <p class="font-heading text-2xl text-secondary mb-2">No posts found</p>
          <p class="text-gray text-sm">Try a different keyword or <button onclick="clearSearch()" class="text-primary font-semibold hover:underline">clear the search</button>.</p>
        </div>

        <div id="pagination" class="mt-12 flex items-center justify-center gap-2"></div>
      </div>
    </section>

    <script id="sanity-posts-data" type="application/json" set:html={SANITY_POSTS_JSON}></script>
  </main>

  <CtaBanner />
</Layout>

<script>
declare global { interface Window { goToPage: (page: number) => void; clearSearch: () => void; } }
const SANITY_POSTS = JSON.parse(document.getElementById('sanity-posts-data')?.textContent || '[]');
const POSTS_PER_PAGE = 6;
const POSTS = [...SANITY_POSTS];

let currentPage = 1;
let filteredPosts = [...POSTS];
let activeTag = 'all';
let activeSearch = '';

function applyFilters() {
  filteredPosts = POSTS.filter(p => {
    const matchesTag = activeTag === 'all' || (p.tags && p.tags.includes(activeTag));
    const q = activeSearch.toLowerCase();
    const matchesSearch = !q || p.title.toLowerCase().includes(q) ||
      (p.excerpt && p.excerpt.toLowerCase().includes(q)) ||
      (p.tags && p.tags.some((t) => t.toLowerCase().includes(q))) ||
      (p.author && p.author.toLowerCase().includes(q));
    return matchesTag && matchesSearch;
  });
  currentPage = 1;
  renderPosts();
}

function renderPosts() {
  const grid = document.getElementById('posts-grid');
  const noResults = document.getElementById('no-results');
  const count = document.getElementById('results-count');
  if (!grid || !noResults || !count) return;

  const start = (currentPage - 1) * POSTS_PER_PAGE;
  const pagePosts = filteredPosts.slice(start, start + POSTS_PER_PAGE);

  if (filteredPosts.length === 0) {
    grid.innerHTML = '';
    noResults.classList.remove('hidden');
    count.textContent = '0 posts';
  } else {
    noResults.classList.add('hidden');
    count.textContent = filteredPosts.length === POSTS.length
      ? `${POSTS.length} posts`
      : `${filteredPosts.length} of ${POSTS.length} posts`;
    grid.innerHTML = pagePosts.map(post => `
      <a href="${post.slug}" class="group bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden no-underline">
        <div class="h-48 overflow-hidden">
          ${post.image ? `<img src="${post.image}" alt="${post.title}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" decoding="async" width="800" height="192" />` : '<div class="w-full h-full bg-gray-light"></div>'}
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-1.5 mb-3">
            ${(post.tags || []).slice(0, 2).map((t) => `<span class="text-xs font-semibold text-gray bg-gray-light rounded-full px-2.5 py-0.5">${t}</span>`).join('')}
          </div>
          <h3 class="font-heading text-xl font-normal text-primary mb-2 leading-snug">${post.title}</h3>
          <p class="text-sm text-gray mb-4 leading-relaxed">${post.excerpt || ''}</p>
          <div class="flex items-center justify-between text-sm text-gray">
            <span>${post.author} · ${post.date}</span>
            <span class="text-primary font-semibold group-hover:underline">Read →</span>
          </div>
        </div>
      </a>
    `).join('');
  }
  renderPagination();
}

function renderPagination() {
  const pagination = document.getElementById('pagination');
  if (!pagination) return;
  const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);

  if (totalPages <= 1) {
    pagination.innerHTML = '';
    return;
  }

  let html = '';
  html += `<button onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="px-4 py-2 rounded-lg border text-sm font-semibold transition-colors min-h-[44px] ${currentPage === 1 ? 'border-gray-200 text-gray/40 cursor-not-allowed' : 'border-gray-300 text-gray hover:bg-gray-light'}">← Prev</button>`;
  for (let i = 1; i <= totalPages; i++) {
    html += `<button onclick="goToPage(${i})" class="w-9 h-9 rounded-lg text-sm font-semibold transition-colors min-h-[44px] ${i === currentPage ? 'bg-primary text-white' : 'border border-gray-300 text-gray hover:bg-gray-light'}">${i}</button>`;
  }
  html += `<button onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} class="px-4 py-2 rounded-lg border text-sm font-semibold transition-colors min-h-[44px] ${currentPage === totalPages ? 'border-gray-200 text-gray/40 cursor-not-allowed' : 'border-gray-300 text-gray hover:bg-gray-light'}">Next →</button>`;
  pagination.innerHTML = html;
}

function goToPage(page: number) {
  const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);
  if (page < 1 || page > totalPages) return;
  currentPage = page;
  renderPosts();
  document.getElementById('posts-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
window.goToPage = goToPage;

function clearSearch() {
  const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
  if (searchInput) searchInput.value = '';
  activeSearch = '';
  activeTag = 'all';
  document.querySelectorAll('.tag-chip').forEach(b => {
    b.classList.remove('active', 'bg-primary', 'text-white', 'border-primary');
    b.classList.add('border-gray-300', 'text-gray');
  });
  const allBtn = document.querySelector('[data-tag="all"]');
  if (allBtn) {
    allBtn.classList.add('bg-primary', 'text-white', 'border-primary');
    allBtn.classList.remove('border-gray-300', 'text-gray');
  }
  applyFilters();
}
window.clearSearch = clearSearch;

// Search
document.getElementById('blog-search')?.addEventListener('input', (e) => {
  activeSearch = (e.target as HTMLInputElement).value.trim();
  applyFilters();
});

// Tag chips
document.querySelectorAll('.tag-chip').forEach(btn => {
  btn.addEventListener('click', () => {
    activeTag = btn.getAttribute('data-tag') || 'all';
    document.querySelectorAll('.tag-chip').forEach(b => {
      b.classList.remove('active', 'bg-primary', 'text-white', 'border-primary');
      b.classList.add('border-gray-300', 'text-gray');
    });
    btn.classList.add('active', 'bg-primary', 'text-white', 'border-primary');
    btn.classList.remove('border-gray-300', 'text-gray');
    applyFilters();
  });
});

// Initial render
renderPosts();
</script>
