---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import PageHero from '../components/PageHero.astro';
import { posts } from '../data/posts';
---

<Layout title="Blog — Johnny Watts Agency" description="Insurance tips, guides, and news from Johnny Watts Agency. Learn about Medicare, health insurance, and life insurance.">

  <PageHero title="Blogs" />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
        {posts.map((post, i) => (
          <article class:list={['blog-card bg-gray-light rounded-lg overflow-hidden hover-lift hover-zoom animate-on-scroll fade-up', { hidden: i >= 6 }]}>
            <img src={post.img} alt={post.title} class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-5">
              <p class="text-xs text-gray mb-2">{post.date}</p>
              <h3 class="text-lg mb-2">
                <a href={post.slug} style="color: #353535; text-decoration: none;" class="hover:text-primary transition-colors">
                  {post.title}
                </a>
              </h3>
              <p class="text-sm text-gray mb-3">{post.excerpt}</p>
              <a href={post.slug} class="text-sm font-semibold" style="color: #4632DA;">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
      <!-- Pagination -->
      <div class="flex justify-center items-center gap-3 mt-12" id="blog-pagination">
        <button id="prev-page" class="px-4 py-2 rounded-md text-sm font-medium" style="background: #f3f4f6; color: #6b7280; cursor: pointer; border: none;" disabled>
          ← Previous
        </button>
        <span id="page-info" style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #6b7280;">Page 1 of {Math.ceil(posts.length / 6)}</span>
        <button id="next-page" class="px-4 py-2 rounded-md text-sm font-medium" style="background: #4632DA; color: #ffffff; cursor: pointer; border: none;">
          Next →
        </button>
      </div>
    </div>
  </section>

  <script>
    const perPage = 6;
    const cards = document.querySelectorAll('.blog-card');
    const totalPages = Math.ceil(cards.length / perPage);
    let currentPage = 1;

    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info')!;

    function showPage(page: number) {
      currentPage = page;
      const start = (page - 1) * perPage;
      const end = start + perPage;
      cards.forEach((card, i) => {
        card.classList.toggle('hidden', i < start || i >= end);
      });
      pageInfo.textContent = `Page ${page} of ${totalPages}`;
      prevBtn.disabled = page === 1;
      prevBtn.style.background = page === 1 ? '#f3f4f6' : '#4632DA';
      prevBtn.style.color = page === 1 ? '#6b7280' : '#ffffff';
      nextBtn.disabled = page === totalPages;
      nextBtn.style.background = page === totalPages ? '#f3f4f6' : '#4632DA';
      nextBtn.style.color = page === totalPages ? '#6b7280' : '#ffffff';
      window.scrollTo({ top: document.getElementById('blog-grid')!.offsetTop - 120, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1); });
    nextBtn.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1); });
  </script>

  <CtaBanner />

</Layout>
