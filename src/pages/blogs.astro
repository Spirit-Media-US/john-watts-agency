---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import PageHero from '../components/PageHero.astro';
import { sanityClient, urlFor } from '../lib/sanity';

const sanityPosts = await sanityClient.fetch(`*[_type == "post"] | order(publishDate desc) {
  _id, title, excerpt, publishDate, author,
  "slug": slug.current,
  heroImage
}`);

const posts = sanityPosts.map((p: any) => ({
  title: p.title,
  slug: `/blog/${p.slug}/`,
  date: new Date(p.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
  excerpt: p.excerpt || '',
  img: p.heroImage ? urlFor(p.heroImage).width(600).auto('format').url() : '',
}));
---

<Layout title="Insurance Blog — Medicare, Health & Life Insurance Tips | Johnny Watts Agency" description="Expert insurance tips, Medicare enrollment guides, and life insurance advice from Johnny Watts Agency. Stay informed about your coverage options in North Carolina.">

  <PageHero title="Blogs" />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
        {posts.map((post, i) => (
          <article class:list={['blog-card bg-gray-light rounded-lg overflow-hidden hover-lift hover-zoom " data-aos="fade-up', { hidden: i >= 6 }]}>
            <img src={post.img} alt={post.title} class="w-full h-48 object-cover" loading="lazy" decoding="async" width="600" height="192" />
            <div class="p-5">
              <p class="text-xs text-gray mb-2">{post.date}</p>
              <h3 class="text-lg mb-2">
                <a href={post.slug} class="text-dark no-underline hover:text-primary transition-colors">
                  {post.title}
                </a>
              </h3>
              <p class="text-sm text-gray mb-3">{post.excerpt}</p>
              <a href={post.slug} class="text-sm font-semibold text-primary">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
      <!-- Pagination -->
      <div class="flex justify-center items-center gap-3 mt-12" id="blog-pagination">
        <button id="prev-page" class="px-5 py-3 rounded-md text-sm font-medium min-h-[44px] bg-gray-light text-gray cursor-pointer border-none" disabled>
          ← Previous
        </button>
        <span id="page-info" class="text-sm text-gray">Page 1 of {Math.ceil(posts.length / 6)}</span>
        <button id="next-page" class="px-5 py-3 rounded-md text-sm font-medium min-h-[44px] bg-primary text-white cursor-pointer border-none">
          Next →
        </button>
      </div>
    </div>
  </section>

  <script>
    const perPage = 6;
    const cards = document.querySelectorAll('.blog-card');
    const totalPages = Math.ceil(cards.length / perPage);
    let currentPage = 1;

    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
    const pageInfo = document.getElementById('page-info');

    function showPage(page: number) {
      if (!prevBtn || !nextBtn || !pageInfo) return;
      currentPage = page;
      const start = (page - 1) * perPage;
      const end = start + perPage;
      cards.forEach((card, i) => {
        card.classList.toggle('hidden', i < start || i >= end);
      });
      pageInfo.textContent = `Page ${page} of ${totalPages}`;
      prevBtn.disabled = page === 1;
      prevBtn.style.background = page === 1 ? '#f3f4f6' : '#4632DA';
      prevBtn.style.color = page === 1 ? '#4b5563' : '#ffffff';
      nextBtn.disabled = page === totalPages;
      nextBtn.style.background = page === totalPages ? '#f3f4f6' : '#4632DA';
      nextBtn.style.color = page === totalPages ? '#4b5563' : '#ffffff';
      const grid = document.getElementById('blog-grid');
      if (grid) window.scrollTo({ top: grid.offsetTop - 120, behavior: 'smooth' });
    }

    prevBtn?.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1); });
    nextBtn?.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1); });
  </script>

  <CtaBanner />

</Layout>
