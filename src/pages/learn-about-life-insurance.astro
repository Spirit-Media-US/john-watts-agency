---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Life Insurance — Johnny Watts Agency" description="Learn about life insurance options including term, whole life, and universal life. Johnny Watts Agency has over 40 years of experience.">

  <section class="bg-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-white mb-3">Learn About Life Insurance</h1>
      <p class="text-gray-300 text-lg">Protect what matters most with the right policy</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 prose prose-lg">
      <!-- Life insurance educational content will be migrated from existing site in Phase 3 -->
      <!-- This is the most content-heavy page — covers term, permanent, whole life, universal, variable -->
      <p class="text-gray">
        Life insurance educational content will be added during the content migration phase. This page will cover term insurance, permanent insurance (whole life, universal life, variable life), and help you understand which type is right for your family.
      </p>
    </div>
  </section>

  <section class="py-12 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-white mb-4">Get a Life Insurance Quote</h2>
      <a href="/life-quote/" class="inline-block px-8 py-3 bg-white text-primary font-semibold rounded-md hover:bg-gray-light transition-colors">
        Get a Quote
      </a>
    </div>
  </section>

</Layout>
