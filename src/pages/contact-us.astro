---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Us — Johnny Watts Agency" description="Contact Johnny Watts Agency in Taylorsville, NC. Call (828) 635-4200 or fill out our contact form.">

  <PageHero title="Contact Us" />

  <!-- Contact heading -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="mb-3">Call Us, Write Us, or Knock on Our Door</h2>
        <p class="text-gray">Get life insurance expertise to secure your future.</p>
      </div>

      <!-- 3-column contact info -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center mb-16">
        <div>
          <h3 class="mb-3">Give Us A Call</h3>
          <a href="tel:8286354200" class="text-dark font-semibold text-xl hover:text-primary transition-colors">(828) 635-4200</a>
        </div>
        <div>
          <h3 class="mb-3">We're On The Map</h3>
          <p class="text-gray">351 NC Hwy 16 S.<br />Taylorsville, NC 28681</p>
        </div>
        <div>
          <h3 class="mb-3">Write Us</h3>
          <a href="mailto:johnny@johnnywattsagency.com" class="text-dark hover:text-primary transition-colors">johnny@johnnywattsagency.com</a>
          <br />
          <a href="mailto:johnny@johnnywattsagency.com" class="text-primary font-semibold hover:text-primary-dark">Email me now!</a>
        </div>
      </div>

      <!-- Business Hours -->
      <div class="text-center mb-16">
        <h3 class="mb-4">Business Hours</h3>
        <p class="text-gray">Monday – Friday: 9:30 AM – 5:00 PM</p>
        <p class="text-gray">Saturday & Sunday: Closed</p>
      </div>

      <!-- CTA -->
      <div class="text-center mb-16">
        <p class="text-xl text-gray mb-4">Secure your future today!</p>
        <a href="/life-quote/" class="btn">
          Life Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="mb-2">Let's have a chat</h2>
      </div>
      <QuoteForm />
    </div>
  </section>

</Layout>
