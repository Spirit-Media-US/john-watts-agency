---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Us — Johnny Watts Agency" description="Contact Johnny Watts Agency in Taylorsville, NC. Call (828) 635-4200 or fill out our contact form.">

  <PageHero title="Contact Us" subtitle="We Would Be Happy To Assist You" />

  <!-- Intro + Hours + Form -->
  <section class="relative py-16 md:py-20 overflow-hidden">
    <!-- Decorative blob — left -->
    <svg class="absolute pointer-events-none animate-pulse-soft" style="left: -100px; top: 20%; width: 300px; height: 400px; opacity: 0.12;" viewBox="0 0 300 400" xmlns="http://www.w3.org/2000/svg">
      <path d="M80,-30 C170,10 260,130 230,270 C200,410 80,420 10,340 C-60,260 -50,80 20,10 C50,-20 50,-40 80,-30 Z" fill="#06D9FA" />
    </svg>

    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="kicker mb-2 animate-on-scroll fade-up" style="color: #06D9FA; font-size: 15px;">Call Us, Write Us, Or Knock On Our Door</p>
      <h2 class="mb-6 animate-on-scroll fade-up stagger-1" style="font-family: 'Varela Round', sans-serif; font-size: clamp(24px, 4vw, 36px); font-weight: 300; color: #3D4459;">Get Life Insurance Expertise To Secure Your Future.</h2>
      <div class="animate-on-scroll fade-up stagger-2" style="font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 400; color: #6b7280;">
        <p>Saturday & Sunday: Closed</p>
        <p>Monday - Friday: 9:30 AM - 5 PM</p>
      </div>

      <!-- Contact Form Card -->
      <div class="mt-10 max-w-lg mx-auto animate-on-scroll fade-up stagger-3">
        <div class="bg-gray-light rounded-xl p-6 md:p-8">
          <QuoteForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Let's Meet cards -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Decorative blob — bottom left -->
    <svg class="absolute pointer-events-none animate-pulse-soft" style="left: -80px; bottom: -40px; width: 250px; height: 300px; opacity: 0.15;" viewBox="0 0 250 300" xmlns="http://www.w3.org/2000/svg">
      <path d="M80,-30 C170,10 220,130 190,250 C160,370 60,380 0,300 C-60,220 -50,80 10,10 C40,-20 50,-40 80,-30 Z" fill="#06D9FA" />
    </svg>
    <!-- Decorative blob — right -->
    <svg class="absolute pointer-events-none animate-float" style="right: -60px; top: 10%; width: 200px; height: 250px; opacity: 0.1;" viewBox="0 0 200 250" xmlns="http://www.w3.org/2000/svg">
      <path d="M120,-20 C180,20 220,100 190,180 C160,260 80,280 30,230 C-20,180 -10,80 40,20 C70,-10 90,-35 120,-20 Z" fill="#4632DA" />
    </svg>

    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-center mb-12 animate-on-scroll fade-up" style="font-family: 'Varela Round', sans-serif; font-size: clamp(28px, 5vw, 42px); font-weight: 300; color: #4632DA;">Let's Meet</h2>

      <!-- 3-column cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Give Us A Call -->
        <div class="animate-on-scroll fade-up stagger-1 hover-lift text-center bg-white rounded-2xl border border-gray-200 p-8" style="box-shadow: 0 2px 12px rgba(0,0,0,0.04);">
          <div class="relative inline-block mb-4">
            <div class="absolute -top-1 -left-2 w-12 h-12 rounded-full" style="background: #e8e8e8;"></div>
            <svg class="relative w-10 h-10" fill="none" stroke="#353535" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
          <h3 style="font-family: 'Varela Round', sans-serif; font-size: 20px; font-weight: 300; color: #3D4459; margin-bottom: 12px;">Give Us A Call</h3>
          <a href="tel:8286354200" style="font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 400; color: #6b7280; text-decoration: none;">828-635-4200</a>
        </div>

        <!-- We're On The Map -->
        <div class="animate-on-scroll fade-up stagger-2 hover-lift text-center bg-white rounded-2xl border border-gray-200 p-8" style="box-shadow: 0 2px 12px rgba(0,0,0,0.04);">
          <div class="relative inline-block mb-4">
            <div class="absolute -top-1 -left-2 w-12 h-12 rounded-full" style="background: #e8e8e8;"></div>
            <svg class="relative w-10 h-10" fill="none" stroke="#353535" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 style="font-family: 'Varela Round', sans-serif; font-size: 20px; font-weight: 300; color: #3D4459; margin-bottom: 12px;">We're On The Map</h3>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 400; color: #6b7280;">351 NC Hwy 16 S. Taylorsville, NC 28681</p>
        </div>

        <!-- Write Us -->
        <div class="animate-on-scroll fade-up stagger-3 hover-lift text-center bg-white rounded-2xl border border-gray-200 p-8" style="box-shadow: 0 2px 12px rgba(0,0,0,0.04);">
          <div class="relative inline-block mb-4">
            <div class="absolute -top-1 -left-2 w-12 h-12 rounded-full" style="background: #e8e8e8;"></div>
            <svg class="relative w-10 h-10" fill="none" stroke="#353535" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </div>
          <h3 style="font-family: 'Varela Round', sans-serif; font-size: 20px; font-weight: 300; color: #3D4459; margin-bottom: 12px;">Write Us</h3>
          <a href="mailto:johnny@johnnywattsagency.com" class="hero-btn inline-flex items-center gap-2 px-6 py-2.5" style="background-color: #06D9FA; color: #ffffff; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 500; text-decoration: none; border-radius: 30px;">
            Email Me Now!
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA — Secure Your Future -->
  <section class="relative overflow-hidden" style="background: linear-gradient(100deg, #4632DA 0%, #2a7de8 40%, #06D9FA 100%); padding: 60px 0;">
    <!-- Curved top -->
    <div class="absolute left-0 w-full overflow-hidden leading-none" style="top: -1px; z-index: 2;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none" style="display: block; width: calc(150% + 10px); position: relative; left: 50%; transform: translateX(-50%); height: 60px;">
        <path d="M0,60 C480,60 960,0 1440,0 L1440,0 L0,0 Z" fill="#ffffff"/>
      </svg>
    </div>
    <div class="relative max-w-4xl mx-auto px-4" style="z-index: 2;">
      <h2 class="mb-6" style="font-family: 'Varela Round', sans-serif; font-size: clamp(24px, 4vw, 36px); font-weight: 300; color: #ffffff;">Secure Your Future Today!</h2>
      <a href="/life-quote/" class="inline-flex items-center gap-2 px-7 py-3 transition-all hover:shadow-lg" style="background-color: #ffffff; color: #06D9FA; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 500; text-transform: capitalize; text-decoration: none; border-radius: 30px;">
        Life Quote
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
      </a>
    </div>
  </section>

</Layout>
