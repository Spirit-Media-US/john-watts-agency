---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<Layout title="Contact Us — Johnny Watts Agency" description="Contact Johnny Watts Agency in Taylorsville, NC. Call (828) 635-4200 or fill out our contact form.">

  <PageHero title="Contact Us" subtitle="We Would Be Happy To Assist You" />

  <!-- Intro + Hours + Form -->
  <section class="relative py-16 md:py-20 overflow-hidden">
    <!-- Decorative blob — left -->
    <svg class="absolute pointer-events-none animate-pulse-soft" style="left: -100px; top: 20%; width: 300px; height: 400px; opacity: 0.12;" viewBox="0 0 300 400" xmlns="http://www.w3.org/2000/svg">
      <path d="M80,-30 C170,10 260,130 230,270 C200,410 80,420 10,340 C-60,260 -50,80 20,10 C50,-20 50,-40 80,-30 Z" fill="#06D9FA" />
    </svg>

    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="kicker mb-2 " data-aos="fade-up" style="color: #06D9FA; font-size: 15px;">Call Us, Write Us, Or Knock On Our Door</p>
      <h2 class="mb-6 " data-aos="fade-up" data-aos-delay="100" style="font-family: 'Varela Round', sans-serif; font-size: clamp(24px, 4vw, 36px); font-weight: 300; color: #3D4459;">Get Life Insurance Expertise To Secure Your Future.</h2>
      <div class="" data-aos="fade-up" data-aos-delay="200" style="font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 400; color: #6b7280;">
        <p>Saturday & Sunday: Closed</p>
        <p>Monday - Friday: 9:30 AM - 5 PM</p>
      </div>

      <!-- Contact Form Card -->
      <div class="mt-10 max-w-lg mx-auto " data-aos="fade-up" data-aos-delay="300">
        <div class="bg-gray-light rounded-xl p-6 md:p-8">
          <QuoteForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Let's Meet cards -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Decorative blob — bottom left -->
    <svg class="absolute pointer-events-none animate-pulse-soft" style="left: -80px; bottom: -40px; width: 250px; height: 300px; opacity: 0.15;" viewBox="0 0 250 300" xmlns="http://www.w3.org/2000/svg">
      <path d="M80,-30 C170,10 220,130 190,250 C160,370 60,380 0,300 C-60,220 -50,80 10,10 C40,-20 50,-40 80,-30 Z" fill="#06D9FA" />
    </svg>
    <!-- Decorative blob — right -->
    <svg class="absolute pointer-events-none animate-float" style="right: -60px; top: 10%; width: 200px; height: 250px; opacity: 0.1;" viewBox="0 0 200 250" xmlns="http://www.w3.org/2000/svg">
      <path d="M120,-20 C180,20 220,100 190,180 C160,260 80,280 30,230 C-20,180 -10,80 40,20 C70,-10 90,-35 120,-20 Z" fill="#4632DA" />
    </svg>

    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center mb-12 " data-aos="fade-up" style="font-family: 'Varela Round', sans-serif; font-size: clamp(28px, 5vw, 42px); font-weight: 300; color: #4632DA;">Let's Meet</h2>

      <!-- 3-column cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Give Us A Call -->
        <div class="hover-lift hover-glow flex flex-col items-center justify-center bg-white border border-gray-200 py-12 px-6" data-aos="fade-up" data-aos-delay="100" style="border-radius: 20px 20px 20px 100px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); min-height: 280px;">
          <div class="relative inline-block mb-6">
            <div class="absolute -top-2 -left-3 w-16 h-16 rounded-full" style="background: #e8e8e8;"></div>
            <svg class="relative w-14 h-14" fill="none" stroke="#353535" stroke-width="1.2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
          <h3 style="font-family: 'Varela Round', sans-serif; font-size: 22px; font-weight: 300; color: #3D4459; margin-bottom: 16px;">Give Us A Call</h3>
          <a href="tel:8286354200" style="font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 400; color: #6b7280; text-decoration: none;">828-635-4200</a>
        </div>

        <!-- We're On The Map -->
        <div class="hover-lift hover-glow flex flex-col items-center justify-center bg-white border border-gray-200 py-12 px-6" data-aos="fade-up" data-aos-delay="200" style="border-radius: 20px 20px 20px 100px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); min-height: 280px;">
          <div class="relative inline-block mb-6">
            <div class="absolute -top-2 -left-3 w-16 h-16 rounded-full" style="background: #e8e8e8;"></div>
            <svg class="relative w-14 h-14" fill="none" stroke="#353535" stroke-width="1.2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 style="font-family: 'Varela Round', sans-serif; font-size: 22px; font-weight: 300; color: #3D4459; margin-bottom: 16px;">We're On The Map</h3>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 400; color: #6b7280; text-align: center;">351 NC Hwy 16 S. Taylorsville, NC 28681</p>
        </div>

        <!-- Write Us -->
        <div class="hover-lift hover-glow flex flex-col items-center justify-center bg-white border border-gray-200 py-12 px-6" data-aos="fade-up" data-aos-delay="300" style="border-radius: 20px 20px 20px 100px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); min-height: 280px;">
          <div class="relative inline-block mb-6">
            <div class="absolute -top-2 -left-3 w-16 h-16 rounded-full" style="background: #e8e8e8;"></div>
            <svg class="relative w-14 h-14" fill="none" stroke="#353535" stroke-width="1.2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </div>
          <h3 style="font-family: 'Varela Round', sans-serif; font-size: 22px; font-weight: 300; color: #3D4459; margin-bottom: 16px;">Write Us</h3>
          <a href="mailto:johnny@johnnywattsagency.com" class="hero-btn inline-flex items-center gap-2 px-7 py-3" style="background-color: #06D9FA; color: #ffffff; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 500; text-decoration: none; border-radius: 30px;">
            Email Me Now!
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Map -->
  <section class="py-0">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3243.5!2d-81.1766!3d35.9218!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8850e8d3b1c6f6a1%3A0x4a0e4f0e8e8e8e8e!2s351%20NC%20Hwy%2016%20S%2C%20Taylorsville%2C%20NC%2028681!5e0!3m2!1sen!2sus!4v1"
      width="100%"
      height="350"
      style="border:0; display:block;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Johnny Watts Agency location"
    ></iframe>
  </section>

  <CtaBanner />

</Layout>
