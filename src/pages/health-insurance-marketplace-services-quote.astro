---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import QuoteForm from '../components/QuoteForm.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Health Insurance Marketplace Quote — Johnny Watts Agency" description="Request a free health insurance marketplace quote. Our specialists will help you find the right plan.">
  <PageHero title="Health Marketplace Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16 bg-gray-light">
    <div class="max-w-xl mx-auto px-4">
      <QuoteForm heading="Health Insurance Marketplace Quote" description="Please complete the form below and one of our agents will be in touch shortly." formName="health-marketplace-quote" />
    </div>
  </section>
  <CtaBanner waveFill="#f3f4f6" />

</Layout>
