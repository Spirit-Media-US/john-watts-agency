---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Free Health Insurance Marketplace Quote | Johnny Watts Agency" description="Get a free ACA Health Insurance Marketplace quote. Our specialists help you find affordable plans that fit your budget and healthcare needs in North Carolina.">
  <PageHero title="Health Marketplace Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16">
    <div class="max-w-xl mx-auto px-4">
      <iframe
        src="https://mail.spiritmediaone.com/widget/form/8pfUmznsvnCLzJLuUw7p"
        style="width:100%;height:100%;border:none;border-radius:0px"
        id="inline-8pfUmznsvnCLzJLuUw7p"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Health Insurance Marketing Services Quote"
        data-height="947"
        data-layout-iframe-id="inline-8pfUmznsvnCLzJLuUw7p"
        data-form-id="8pfUmznsvnCLzJLuUw7p"
        title="Health Insurance Marketing Services Quote"
      ></iframe>
      <script is:inline src="https://mail.spiritmediaone.com/js/form_embed.js"></script>
    </div>
  </section>
  <CtaBanner waveFill="#f3f4f6" />

</Layout>
