---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Free Medicare Quote | Johnny Watts Agency — Taylorsville, NC" description="Request a free, no-obligation Medicare quote. Our licensed agents will help you compare Medicare Advantage, Supplement, and Part D plans for North Carolina.">
  <PageHero title="Medicare Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16">
    <div class="max-w-xl mx-auto px-4">
      <iframe
          data-lazy-src="https://mail.spiritmediaone.com/widget/form/YkuHIeiB5We3yKm4z9yG"
        style="display:block;width:100%;height:590px;border:none;border-radius:0px"
        id="inline-YkuHIeiB5We3yKm4z9yG"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Medicare Quote"
        data-height="590"
        data-layout-iframe-id="inline-YkuHIeiB5We3yKm4z9yG"
        data-form-id="YkuHIeiB5We3yKm4z9yG"
        title="Medicare Quote"
      ></iframe>
</div>
  </section>
  <CtaBanner waveFill="#f3f4f6" />

<script is:inline>
(function(){
  var loaded = false;
  function loadGhl(){
    if (loaded) return; loaded = true;
    var iframes = document.querySelectorAll('iframe[data-lazy-src]');
    iframes.forEach(function(f){ f.src = f.dataset.lazySrc; });
    if (iframes.length) {
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://mail.spiritmediaone.com/js/form_embed.js';
      document.body.appendChild(s);
    }
  }
  var evts = ['touchstart','keydown','click','pointerdown'];
  function t(){ evts.forEach(function(e){ window.removeEventListener(e,t); }); loadGhl(); }
  evts.forEach(function(e){ window.addEventListener(e,t,{passive:true,once:true}); });
  setTimeout(loadGhl, 60000);
})();
</script>
</Layout>
