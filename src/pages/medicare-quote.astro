---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import QuoteForm from '../components/QuoteForm.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Medicare Quote — Johnny Watts Agency" description="Request a free Medicare quote from Johnny Watts Agency. Our agents will contact you to discuss your options.">
  <PageHero title="Medicare Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-0 bg-gray-light">
    <div class="max-w-xl mx-auto px-4">
      <QuoteForm heading="Get a Medicare Quote" description="Please complete the form below and one of our agents will be in touch shortly." />
    </div>
  </section>
  <CtaBanner />

</Layout>
