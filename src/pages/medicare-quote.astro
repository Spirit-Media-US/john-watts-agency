---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Free Medicare Quote | Johnny Watts Agency — Taylorsville, NC" description="Request a free, no-obligation Medicare quote. Our licensed agents will help you compare Medicare Advantage, Supplement, and Part D plans for North Carolina.">
  <PageHero title="Medicare Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16">
    <div class="max-w-xl mx-auto px-4">
      <div class="bg-gray-light rounded-xl p-6 md:p-8">
        <h1 class="text-center mb-4 text-secondary">Get a Medicare Quote</h1>
        <p class="text-center text-gray mb-8">Please complete the form below and one of our agents will be in touch shortly.</p>
        <iframe
          src="https://mail.spiritmediaone.com/widget/form/YkuHIeiB5We3yKm4z9yG"
          style="width:100%;height:100%;border:none;border-radius:0px"
          id="inline-YkuHIeiB5We3yKm4z9yG"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Medicare Quote"
          data-height="590"
          data-layout-iframe-id="inline-YkuHIeiB5We3yKm4z9yG"
          data-form-id="YkuHIeiB5We3yKm4z9yG"
          title="Medicare Quote"
        ></iframe>
        <script is:inline src="https://mail.spiritmediaone.com/js/form_embed.js"></script>
      </div>
    </div>
  </section>
  <CtaBanner waveFill="#f3f4f6" />

</Layout>
