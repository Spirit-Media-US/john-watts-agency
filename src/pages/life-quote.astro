---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import GhlForm from '../components/GhlForm.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Free Life Insurance Quote | Johnny Watts Agency — Taylorsville, NC" description="Get a free life insurance quote from Johnny Watts Agency. Compare term, whole life, and universal life options to protect your family's future.">
  <PageHero title="Life Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16">
    <div class="max-w-xl mx-auto px-4">
      <div class="bg-gray-light rounded-xl p-6 md:p-8">
        <GhlForm formId="LKUbJs0j6QIUE9dJwVLD" formName="Life Quote" height={888} heading="Get a Life Insurance Quote" description="Please complete the form below and one of our agents will be in touch shortly." />
      </div>
    </div>
  </section>
  <CtaBanner waveFill="#f3f4f6" />

</Layout>
