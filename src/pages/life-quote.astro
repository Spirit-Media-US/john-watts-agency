---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Life Insurance Quote — Johnny Watts Agency" description="Request a free life insurance quote from Johnny Watts Agency. Protect your family with the right coverage.">
  <PageHero title="Life Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16 bg-gray-light">
    <div class="max-w-xl mx-auto px-4">
      <QuoteForm heading="Get a Life Insurance Quote" description="Please complete the form below and one of our agents will be in touch shortly." />
    </div>
  </section>
</Layout>
