---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Free Life Insurance Quote | Johnny Watts Agency — Taylorsville, NC" description="Get a free life insurance quote from Johnny Watts Agency. Compare term, whole life, and universal life options to protect your family's future.">
  <PageHero title="Life Quote" waveFill="#f3f4f6" />
  <section class="pt-4 pb-16">
    <div class="max-w-xl mx-auto px-4">
      <iframe
          data-lazy-src="https://mail.spiritmediaone.com/widget/form/LKUbJs0j6QIUE9dJwVLD"
        style="display:block;width:100%;height:947px;border:none;border-radius:0px"
        id="inline-LKUbJs0j6QIUE9dJwVLD"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Life Quote"
        data-height="947"
        data-layout-iframe-id="inline-LKUbJs0j6QIUE9dJwVLD"
        data-form-id="LKUbJs0j6QIUE9dJwVLD"
        title="Life Quote"
      ></iframe>
</div>
  </section>
  <CtaBanner waveFill="#f3f4f6" />

<script is:inline>
(function(){
  var loaded = false;
  function loadGhl(){
    if (loaded) return; loaded = true;
    var iframes = document.querySelectorAll('iframe[data-lazy-src]');
    iframes.forEach(function(f){ f.src = f.dataset.lazySrc; });
    if (iframes.length) {
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://mail.spiritmediaone.com/js/form_embed.js';
      document.body.appendChild(s);
    }
  }
  var evts = ['scroll','mousemove','touchstart','keydown','click'];
  function t(){ evts.forEach(function(e){ window.removeEventListener(e,t); }); loadGhl(); }
  evts.forEach(function(e){ window.addEventListener(e,t,{passive:true,once:true}); });
  setTimeout(loadGhl, 60000);
})();
</script>
</Layout>
